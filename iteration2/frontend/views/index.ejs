<%- include('partials/header', { pageTitle: 'IlmQuest', pageStyles: ['/css/pages/landing.css'] }) -%>

<svg class="landing-icon-sprite" aria-hidden="true" focusable="false">
  <symbol id="icon-sparkle" viewBox="0 0 24 24"><path d="M12 3 13.8 8.2 19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z"/></symbol>
  <symbol id="icon-chevron-right" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></symbol>
  <symbol id="icon-book-open" viewBox="0 0 24 24"><path d="M2 4h6a4 4 0 0 1 4 4v12a3 3 0 0 0-3-3H2z"/><path d="M22 4h-6a4 4 0 0 0-4 4v12a3 3 0 0 1 3-3h7z"/></symbol>
  <symbol id="icon-graduation-cap" viewBox="0 0 24 24"><path d="m2 10 10-5 10 5-10 5z"/><path d="M6 12v5c3 2 9 2 12 0v-5"/></symbol>
  <symbol id="icon-users" viewBox="0 0 24 24"><circle cx="8" cy="8" r="3"/><circle cx="16" cy="9" r="2.5"/><path d="M2.5 20a5.5 5.5 0 0 1 11 0"/><path d="M12.5 20a4.5 4.5 0 0 1 9 0"/></symbol>
  <symbol id="icon-trophy" viewBox="0 0 24 24"><path d="M8 21h8"/><path d="M12 17v4"/><path d="M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M5 6H3a2 2 0 0 0 0 4h2"/><path d="M19 6h2a2 2 0 0 1 0 4h-2"/></symbol>
  <symbol id="icon-check" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></symbol>
  <symbol id="icon-star" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></symbol>
  <symbol id="icon-zap" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></symbol>
  <symbol id="icon-shield" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></symbol>
  <symbol id="icon-globe" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></symbol>
</svg>

<main class="landing-shell">

  <!-- ═══ HERO ═══ -->
  <section class="landing-hero" aria-labelledby="landing-hero-title">
    <div class="hero-orbs" aria-hidden="true">
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>
    <div class="landing-container hero-content">
      <div class="hero-badge reveal">
        <svg class="landing-icon hero-badge-icon"><use href="#icon-sparkle"/></svg>
        <span>Trusted by 500+ Islamic Schools</span>
        <svg class="landing-icon hero-badge-icon"><use href="#icon-sparkle"/></svg>
      </div>
      <h1 class="hero-title reveal" id="landing-hero-title">
        Nurturing Hearts & Minds
        <span class="highlight">Through Islamic Education</span>
      </h1>
      <p class="hero-text reveal">
        A comprehensive digital platform for Quran memorization, Islamic studies,
        and academic excellence — built for the way marakiz actually work.
      </p>
      <p class="hero-arabic reveal" lang="ar" dir="rtl">خَيْرُكُم مَّن تَعَلَّمَ ٱلْقُرْآنَ وَعَلَّمَهُ</p>
      <p class="hero-translation reveal">"The best of you are those who learn the Quran and teach it" — Sahih Al-Bukhari</p>
      <div class="cta-row reveal" role="group" aria-label="Primary actions">
        <a class="primary-btn" href="/login">
          Access Your School
          <svg class="landing-icon btn-icon" aria-hidden="true"><use href="#icon-chevron-right"/></svg>
        </a>
        <a class="secondary-btn" href="#pricing">View Pricing</a>
      </div>
    </div>
  </section>

  <!-- ═══ STATS ═══ -->
  <section class="stats" aria-label="Platform statistics">
    <div class="landing-container stats-grid">
      <div class="stat-card reveal">
        <div class="stat-value">500+</div>
        <div class="stat-label">Partner Schools</div>
      </div>
      <div class="stat-card reveal">
        <div class="stat-value">30+</div>
        <div class="stat-label">District Programs</div>
      </div>
      <div class="stat-card reveal">
        <div class="stat-value">95%</div>
        <div class="stat-label">School Retention</div>
      </div>
      <div class="stat-card reveal">
        <div class="stat-value">10+</div>
        <div class="stat-label">Years Serving Schools</div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURES ═══ -->
  <section class="features" id="features" aria-labelledby="features-title">
    <div class="landing-container">
      <div class="section-head reveal">
        <h2 id="features-title">Everything You Need to Excel</h2>
        <p>Comprehensive tools for students, teachers, and parents — tracking progress, building habits, and achieving goals.</p>
      </div>
      <div class="feature-grid">
        <article class="feature-card reveal">
          <div class="icon-pill" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-book-open"/></svg>
          </div>
          <h3>Quran Memorization</h3>
          <p>Track every student's Hifz journey with personalized goals, progress logs, and daily targets.</p>
        </article>
        <article class="feature-card reveal">
          <div class="icon-pill" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-graduation-cap"/></svg>
          </div>
          <h3>Academic Excellence</h3>
          <p>Full curriculum coverage — Islamic studies, Arabic, and core subjects with grade tracking.</p>
        </article>
        <article class="feature-card reveal">
          <div class="icon-pill" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-users"/></svg>
          </div>
          <h3>Parent Portal</h3>
          <p>Real-time updates, announcements, and progress reports keep families deeply connected.</p>
        </article>
        <article class="feature-card reveal">
          <div class="icon-pill" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-trophy"/></svg>
          </div>
          <h3>Gamified Learning</h3>
          <p>Earn XP, complete missions, unlock ranks — motivation built right into the platform.</p>
        </article>
        <article class="feature-card reveal">
          <div class="icon-pill" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-zap"/></svg>
          </div>
          <h3>Smart Attendance</h3>
          <p>One-click class attendance with calendar views, absence tracking, and downloadable reports.</p>
        </article>
        <article class="feature-card reveal">
          <div class="icon-pill" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-shield"/></svg>
          </div>
          <h3>Multi-Tenant Security</h3>
          <p>Every school is isolated with its own data, roles, and permissions — no cross-contamination.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══ PRICING ═══ -->
  <section class="pricing" id="pricing" aria-labelledby="pricing-title">
    <div class="pricing-orbs" aria-hidden="true">
      <div class="pricing-orb pricing-orb-1"></div>
      <div class="pricing-orb pricing-orb-2"></div>
    </div>
    <div class="landing-container">
      <div class="section-head reveal">
        <div class="pricing-badge">School Plans</div>
        <h2 id="pricing-title">Simple, Transparent Pricing</h2>
        <p>Every plan includes full platform access. Scale as your school grows.</p>
      </div>

      <div class="pricing-grid">

        <article class="pricing-card reveal">
          <div class="pricing-tier">Starter</div>
          <div class="pricing-price">
            <span class="price-amount">$49</span>
            <span class="price-period">/month</span>
          </div>
          <p class="pricing-desc">Perfect for small marakiz getting started with digital management.</p>
          <ul class="pricing-features">
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Up to 100 students</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Quran progress tracking</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Attendance management</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Parent portal</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Grade reporting</li>
            <li class="pricing-feature-muted"><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Email support</li>
          </ul>
          <a class="pricing-cta secondary-btn" href="/login">Get Started</a>
        </article>

        <article class="pricing-card pricing-card-featured reveal">
          <div class="pricing-popular-badge">Most Popular</div>
          <div class="pricing-tier">Growth</div>
          <div class="pricing-price">
            <span class="price-amount">$149</span>
            <span class="price-period">/month</span>
          </div>
          <p class="pricing-desc">For established schools ready for advanced tools and gamification.</p>
          <ul class="pricing-features">
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Up to 500 students</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Everything in Starter</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Missions & XP gamification</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Student library</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Finance tracking</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Priority support</li>
          </ul>
          <a class="pricing-cta primary-btn" href="/login">Get Started</a>
        </article>

        <article class="pricing-card reveal">
          <div class="pricing-tier">Enterprise</div>
          <div class="pricing-price">
            <span class="price-amount">Custom</span>
          </div>
          <p class="pricing-desc">For large institutions, districts, or multi-campus organizations.</p>
          <ul class="pricing-features">
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Unlimited students</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Everything in Growth</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Custom branding</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Dedicated account manager</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> SLA & uptime guarantee</li>
            <li><svg class="landing-icon check-icon"><use href="#icon-check"/></svg> Onboarding & training</li>
          </ul>
          <a class="pricing-cta secondary-btn" href="mailto:support@ilmquest.com">Contact Sales</a>
        </article>

      </div>

      <p class="pricing-note reveal">All plans include a 14-day free trial. No credit card required to start.</p>
    </div>
  </section>

  <!-- ═══ AUDIENCE ═══ -->
  <section class="audience" aria-labelledby="audience-title">
    <div class="landing-container">
      <div class="section-head reveal">
        <h2 id="audience-title">Designed for Everyone</h2>
        <p>Tailored dashboards and tools for every member of your educational community.</p>
      </div>
      <div class="audience-grid">
        <article class="audience-card audience-card-students reveal">
          <div class="audience-icon" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-graduation-cap"/></svg>
          </div>
          <h3>Students</h3>
          <p>Track Quran progress, complete missions, earn XP and rewards on your journey.</p>
          <a class="secondary-btn audience-btn" href="/login">View Dashboard</a>
        </article>
        <article class="audience-card audience-card-teachers reveal">
          <div class="audience-icon" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-book-open"/></svg>
          </div>
          <h3>Teachers</h3>
          <p>Manage classes, record attendance, track student performance, and assign missions.</p>
          <a class="secondary-btn audience-btn" href="/login">View Dashboard</a>
        </article>
        <article class="audience-card audience-card-parents reveal">
          <div class="audience-icon" aria-hidden="true">
            <svg class="landing-icon"><use href="#icon-users"/></svg>
          </div>
          <h3>Parents</h3>
          <p>Stay connected with real-time progress updates and school announcements.</p>
          <a class="secondary-btn audience-btn" href="/login">View Dashboard</a>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══ FINAL CTA ═══ -->
  <section class="cta-final" aria-labelledby="final-cta-title">
    <div class="cta-orbs" aria-hidden="true">
      <div class="cta-orb"></div>
    </div>
    <div class="landing-container">
      <div class="cta-card reveal">
        <div class="stars" aria-hidden="true">
          <svg class="landing-icon"><use href="#icon-sparkle"/></svg>
          <svg class="landing-icon"><use href="#icon-sparkle"/></svg>
          <svg class="landing-icon"><use href="#icon-sparkle"/></svg>
        </div>
        <h2 id="final-cta-title">Ready to Begin Your Journey?</h2>
        <p>Join hundreds of Islamic schools already using IlmQuest to transform how they teach, track, and inspire.</p>
        <div class="cta-row">
          <a class="primary-btn" href="/login">
            Access Your School
            <svg class="landing-icon btn-icon" aria-hidden="true"><use href="#icon-chevron-right"/></svg>
          </a>
          <a class="secondary-btn" href="#pricing">See Pricing</a>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') -%>
