<%
  const teacherActivePage = 'grades';
  const teacherPageTitle = 'Grade Management';
  const teacherPageSubtitle = 'Institutional spreadsheet gradebook with event-backed accuracy, comments, undo, and exports.';
  const pageStyles = ['/css/pages/teacher-gradebook-v1.css'];
  const pageScripts = ['/js/shared-calculations.bundle.js', '/js/teacher-gradebook-app.js'];
  const page = locals.gradebookPage || {};
  const classes = Array.isArray(page.classes) ? page.classes : [];
  const activeClassId = page.activeClassId || classes?.[0]?.id || '';
  const successMessages = Array.isArray(messages?.success) ? messages.success : [];
  const errorMessages = [
    ...(Array.isArray(messages?.error) ? messages.error : []),
    ...(Array.isArray(messages?.errors) ? messages.errors.map((entry) => entry?.msg || entry).filter(Boolean) : [])
  ];
%>
<%- include('../partials/teacherHeader') %>

<main
  class="teacher-main gradebook-v1-page"
  x-data="gradebookDrawer()"
  x-on:keydown.escape.window="close()"
>
  <section class="teacher-page-shell gradebook-v1-shell">
    <% if (successMessages.length) { %>
      <div class="gradebook-v1-flash gradebook-v1-flash-success"><%= successMessages.join(' ') %></div>
    <% } %>
    <% if (errorMessages.length) { %>
      <div class="gradebook-v1-flash gradebook-v1-flash-error"><%= errorMessages.join(' ') %></div>
    <% } %>

    <header class="gradebook-v1-hero">
      <div>
        <p class="gradebook-v1-kicker">IlmQuest Grading V1</p>
        <h1>Spreadsheet-first institutional gradebook</h1>
        <p>Students stay vertical, dates stretch across the top, grouped columns stay fast, and every cell save lands in an append-mostly audit trail.</p>
      </div>
      <div class="gradebook-v1-hero-stats">
        <article>
          <span>Classes</span>
          <strong><%= classes.length %></strong>
        </article>
        <article>
          <span>Key System</span>
          <strong><%= page.keySystemVersion || 'albayaan.v1' %></strong>
        </article>
        <article>
          <span>Workflow</span>
          <strong>Live Spreadsheet</strong>
        </article>
      </div>
    </header>

    <% if (!classes.length) { %>
      <section class="gradebook-v1-empty">
        <h2>No classes assigned yet</h2>
        <p>Once classes are assigned to you, the grading grid, assessments, exports, and comments drawer will appear automatically.</p>
      </section>
    <% } else { %>
      <nav class="gradebook-v1-tabs" aria-label="Teacher classes">
        <% classes.forEach((classView, classIndex) => { %>
          <button
            class="gradebook-v1-tab <%= String(classView.id) === String(activeClassId) || (!activeClassId && classIndex === 0) ? 'is-active' : '' %>"
            type="button"
            data-gradebook-class-tab
            data-class-id="<%= classView.id %>"
          >
            <span><%= classView.className %></span>
            <small><%= classView.studentCount %> students</small>
          </button>
        <% }) %>
      </nav>

      <% classes.forEach((classView, classIndex) => { %>
        <%- include('../partials/gradebook/teacherGradebookClassPanel', { classView, classIndex, csrfToken, activeClassId }) %>
      <% }) %>
    <% } %>
  </section>

  <%- include('../partials/gradebook/teacherGradebookDrawer', { csrfToken }) %>
</main>

<script id="teacherGradebookPayload" type="application/json"><%- JSON.stringify({ csrfToken, classes, activeClassId, focusDateKey: page.focusDateKey || '' }).replace(/</g, '\\u003c') %></script>

<%- include('../partials/teacherFooter') %>
