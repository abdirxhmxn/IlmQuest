<%
  const teacherActivePage = 'customize';
  const teacherPageTitle = 'Class Customization';
  const teacherPageSubtitle = 'Configure class dashboard layout, subjects, and grading systems.';
%>
<%- include('../partials/teacherHeader') %>

<link rel="stylesheet" href="/css/pages/teacher-customization.css">

<main class="teacher-main teacher-customization-page">
  <section class="teacher-page-shell settings-shell">
    <header class="teacher-page-hero settings-header">
      <div>
        <h1>Class Customization</h1>
        <p>Configure your dashboard layout, subjects, grading categories, and the two teacher-facing grading systems for each class.</p>
      </div>
      <a href="/teacher/home" class="btn-secondary">Back To Dashboard</a>
    </header>

    <% const successMessages = (typeof messages !== 'undefined' && messages.success) ? messages.success : []; %>
    <% const errorMessages = (typeof messages !== 'undefined' && messages.error) ? messages.error : []; %>
    <% if (successMessages.length > 0) { %>
      <div class="flash-message success"><%= successMessages.join(' ') %></div>
    <% } %>
    <% if (errorMessages.length > 0) { %>
      <div class="flash-message error"><%= errorMessages.join(' ') %></div>
    <% } %>

    <% if (!classes || classes.length === 0) { %>
      <div class="empty-state">
        <h2>No Classes Assigned Yet</h2>
        <p>Once an admin assigns you to a class, your customization controls will appear here.</p>
      </div>
    <% } else { %>
      <div class="class-selector">
        <% classes.forEach((cls) => { %>
          <a
            class="class-pill <%= String(selectedClass?._id) === String(cls._id) ? 'active' : '' %>"
            href="/teacher/customize?classId=<%= cls._id %>"
          >
            <span class="class-pill-title"><%= cls.className %></span>
            <span class="class-pill-meta"><%= (cls.students || []).length %> students</span>
          </a>
        <% }) %>
      </div>

      <% if (selectedClass) { %>
        <%
          const selectedScaleSet = selectedClass.teacherSettings?.gradingScales || defaultGradingScaleSet;
          const memorizationScale = selectedScaleSet?.memorization || defaultGradingScaleSet.memorization;
          const subacScale = selectedScaleSet?.subac || defaultGradingScaleSet.subac;
          const activeSubjectCount = (selectedClass.activeSubjects || []).length;
          const activeCategoryCount = (selectedClass.activeGradingCategories || []).length;
        %>

        <article class="settings-card">
          <header class="card-header">
            <div>
              <h2><%= selectedClass.className %></h2>
              <p>Class code: <strong><%= selectedClass.classCode %></strong></p>
            </div>
            <div class="meta-grid">
              <div>
                <span class="meta-label">Subjects</span>
                <span class="meta-value"><%= activeSubjectCount %></span>
              </div>
              <div>
                <span class="meta-label">Categories</span>
                <span class="meta-value"><%= activeCategoryCount %></span>
              </div>
              <div>
                <span class="meta-label">Grading Systems</span>
                <span class="meta-value">2</span>
              </div>
              <div>
                <span class="meta-label">Schema Version</span>
                <span class="meta-value">v<%= selectedClass.currentConfigVersion || 1 %></span>
              </div>
              <div>
                <span class="meta-label">Recorded Grades</span>
                <span class="meta-value"><%= selectedClass.gradeCount || 0 %></span>
              </div>
            </div>
          </header>

          <% if ((selectedClass.gradeCount || 0) > 0) { %>
            <div class="history-warning">
              <strong>Historical Data Notice:</strong>
              This class already has recorded grades. Structural grading changes will create a new schema version, while older grades keep the mark snapshot that was saved at the time.
            </div>
          <% } %>

          <form id="customizationForm" action="/teacher/customize/<%= selectedClass._id %>" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="sectionsJson" id="sectionsJson">
            <input type="hidden" name="subjectsJson" id="subjectsJson">
            <input type="hidden" name="gradingCategoriesJson" id="gradingCategoriesJson">
            <input type="hidden" name="memorizationScaleJson" id="memorizationScaleJson">
            <input type="hidden" name="subacScaleJson" id="subacScaleJson">

            <section class="form-section">
              <h3>Page Setup</h3>
              <div class="field-grid">
                <div class="field">
                  <label for="displayTitle">Class Display Title</label>
                  <input
                    id="displayTitle"
                    name="displayTitle"
                    type="text"
                    maxlength="90"
                    value="<%= selectedClass.teacherSettings?.displayTitle || selectedClass.className %>"
                    placeholder="e.g., Grade 3 Qur'an Mastery"
                    required
                  >
                </div>
                <div class="field">
                  <label for="dashboardLayout">Dashboard Layout Style</label>
                  <select id="dashboardLayout" name="dashboardLayout" required>
                    <% dashboardLayouts.forEach((layout) => { %>
                      <option
                        value="<%= layout %>"
                        <%= selectedClass.teacherSettings?.dashboardLayout === layout ? 'selected' : '' %>
                      >
                        <%= layout.charAt(0).toUpperCase() + layout.slice(1) %>
                      </option>
                    <% }) %>
                  </select>
                </div>
              </div>
              <div class="field">
                <label for="welcomeMessage">Welcome Message</label>
                <textarea
                  id="welcomeMessage"
                  name="welcomeMessage"
                  rows="3"
                  maxlength="220"
                  placeholder="Write a concise message for your class dashboard."
                ><%= selectedClass.teacherSettings?.welcomeMessage || '' %></textarea>
              </div>
              <div class="field">
                <label for="customizationReason">Change Note (optional)</label>
                <input
                  id="customizationReason"
                  name="customizationReason"
                  type="text"
                  maxlength="160"
                  placeholder="e.g., Updated Subac settings for weekend revision cycle"
                >
              </div>
            </section>

            <section class="form-section">
              <div class="section-head">
                <h3>Dashboard Sections</h3>
                <p>Toggle visibility and set order for dashboard blocks.</p>
              </div>
              <div class="list-grid" id="dashboardSectionsList">
                <% (selectedClass.teacherSettings?.dashboardSections || []).forEach((section) => { %>
                  <div class="list-row section-row" data-section-key="<%= section.key %>">
                    <input type="hidden" class="section-key" value="<%= section.key %>">
                    <div class="row-main">
                      <label>Label</label>
                      <input type="text" class="section-label" value="<%= section.label %>" maxlength="50">
                    </div>
                    <div class="row-small">
                      <label>Visible</label>
                      <input type="checkbox" class="section-visible" <%= section.visible ? 'checked' : '' %>>
                    </div>
                    <div class="row-small">
                      <label>Order</label>
                      <input type="number" class="section-order" min="0" value="<%= section.order %>">
                    </div>
                  </div>
                <% }) %>
              </div>
            </section>

            <section class="form-section">
              <div class="section-head">
                <h3>Subjects Taught</h3>
                <p>Set subjects shown on your class pages. Removing a subject archives it for historical grade safety.</p>
              </div>
              <div class="list-grid" id="subjectsList">
                <% (selectedClass.teacherSettings?.subjectConfig || []).forEach((subject) => { %>
                  <div class="list-row subject-row" data-is-archived="<%= subject.isArchived ? 'true' : 'false' %>">
                    <input type="hidden" class="subject-key" value="<%= subject.key %>">
                    <div class="row-main">
                      <label>Subject Label</label>
                      <input type="text" class="subject-name" maxlength="60" value="<%= subject.label || subject.name %>" required>
                      <small class="row-meta">Key: <%= subject.key %></small>
                    </div>
                    <div class="row-small">
                      <label>Visible</label>
                      <input type="checkbox" class="subject-active" <%= subject.active && !subject.isArchived ? 'checked' : '' %>>
                    </div>
                    <div class="row-small">
                      <label>Order</label>
                      <input type="number" class="subject-order" min="0" value="<%= subject.order %>">
                    </div>
                    <div class="row-actions">
                      <span class="status-badge <%= subject.isArchived ? 'archived' : (subject.active ? 'active' : 'inactive') %>">
                        <%= subject.isArchived ? 'Archived' : (subject.active ? 'Active' : 'Hidden') %>
                      </span>
                      <button type="button" class="btn-danger remove-row">Remove</button>
                    </div>
                  </div>
                <% }) %>
              </div>
              <button type="button" class="btn-secondary add-row" id="addSubjectBtn">Add Subject</button>
            </section>

            <section class="form-section">
              <div class="section-head">
                <h3>Grading Categories</h3>
                <p>Rename, enable, and weight categories. Active weights must equal 100%. Removed categories are archived for history.</p>
              </div>
              <div class="list-grid" id="categoriesList">
                <% (selectedClass.teacherSettings?.gradingCategories || []).forEach((category) => { %>
                  <div class="list-row category-row" data-is-default="<%= category.isDefault ? 'true' : 'false' %>" data-is-archived="<%= category.isArchived ? 'true' : 'false' %>">
                    <input type="hidden" class="category-key" value="<%= category.key %>">
                    <input type="hidden" class="category-default" value="<%= category.isDefault ? 'true' : 'false' %>">
                    <div class="row-main">
                      <label>Category Label</label>
                      <input type="text" class="category-name" maxlength="60" value="<%= category.label || category.name %>" required>
                      <small class="row-meta">Key: <%= category.key %></small>
                    </div>
                    <div class="row-small">
                      <label>Weight %</label>
                      <input type="number" class="category-weight" min="0" max="100" step="0.1" value="<%= category.weight %>" required>
                    </div>
                    <div class="row-small">
                      <label>Active</label>
                      <input type="checkbox" class="category-active" <%= category.active && !category.isArchived ? 'checked' : '' %>>
                    </div>
                    <div class="row-small">
                      <label>Order</label>
                      <input type="number" class="category-order" min="0" value="<%= category.order %>">
                    </div>
                    <div class="row-actions">
                      <span class="status-badge <%= category.isArchived ? 'archived' : (category.active ? 'active' : 'inactive') %>">
                        <%= category.isArchived ? 'Archived' : (category.active ? 'Active' : 'Hidden') %>
                      </span>
                      <button
                        type="button"
                        class="btn-danger remove-row"
                        <%= category.isDefault ? 'disabled' : '' %>
                      >
                        <%= category.isDefault ? 'Default' : 'Remove' %>
                      </button>
                    </div>
                  </div>
                <% }) %>
              </div>
              <div class="weight-summary" id="weightSummary">Active Weight Total: 0%</div>
              <button type="button" class="btn-secondary add-row" id="addCategoryBtn">Add Category</button>
            </section>

            <section class="form-section">
              <div class="section-head">
                <h3>Grading Systems</h3>
                <p>Manage the default Al Bayaan memorization scale separately from the Subac revision scale. Hidden marks stay readable in historical records because saved grades keep their original snapshot.</p>
              </div>

              <div class="scale-stack">
                <% [
                  {
                    key: 'memorization',
                    title: memorizationScale.name,
                    helper: 'Used for daily Cashar, Writing, and Subject grading in the spreadsheet chart.',
                    restoreLabel: 'Restore Al Bayaan Default',
                    scale: memorizationScale
                  },
                  {
                    key: 'subac',
                    title: subacScale.name,
                    helper: 'Used only for Subac / revision review entries, counts, and percentage calculations.',
                    restoreLabel: 'Restore Subac Default',
                    scale: subacScale
                  }
                ].forEach((scaleSection) => { %>
                  <article class="scale-card" data-scale-editor="<%= scaleSection.key %>">
                    <header class="scale-card-header">
                      <div>
                        <h4><%= scaleSection.title %></h4>
                        <p><%= scaleSection.helper %></p>
                      </div>
                      <button
                        type="button"
                        class="btn-secondary scale-reset-btn"
                        data-scale-restore="<%= scaleSection.key %>"
                      >
                        <%= scaleSection.restoreLabel %>
                      </button>
                    </header>

                    <div class="scale-card-grid">
                      <% (scaleSection.scale.marks || []).forEach((mark) => { %>
                        <div class="scale-row" data-scale-row data-scale-system="<%= scaleSection.key %>">
                          <input type="hidden" class="scale-mark-key" value="<%= mark.key %>">
                          <input type="hidden" class="scale-mark-symbol" value="<%= mark.symbol %>">

                          <div class="scale-symbol-card">
                            <span class="scale-symbol"><%= mark.symbol %></span>
                            <small class="row-meta">Key: <%= mark.key %></small>
                          </div>

                          <div class="scale-field scale-field-wide">
                            <label>Label</label>
                            <input
                              type="text"
                              class="scale-mark-label"
                              maxlength="90"
                              value="<%= mark.label %>"
                              required
                            >
                          </div>

                          <div class="scale-field scale-field-wide">
                            <label>Description</label>
                            <input
                              type="text"
                              class="scale-mark-description"
                              maxlength="200"
                              value="<%= mark.description || '' %>"
                              placeholder="Optional description shown in grade details"
                            >
                          </div>

                          <div class="scale-field">
                            <label>Points</label>
                            <input
                              type="number"
                              class="scale-mark-value"
                              min="0"
                              max="<%= scaleSection.scale.maxValue %>"
                              step="0.1"
                              value="<%= mark.value %>"
                            >
                          </div>

                          <div class="scale-field">
                            <label>Order</label>
                            <input
                              type="number"
                              class="scale-mark-order"
                              min="0"
                              step="1"
                              value="<%= mark.sortOrder %>"
                            >
                          </div>

                          <label class="scale-toggle">
                            <span>Active</span>
                            <input type="checkbox" class="scale-mark-active" <%= mark.active ? 'checked' : '' %>>
                          </label>

                          <label class="scale-toggle">
                            <span>Counts In Grade</span>
                            <input type="checkbox" class="scale-mark-counts" <%= mark.countsTowardGrade ? 'checked' : '' %>>
                          </label>

                          <div class="scale-row-meta">
                            <span class="status-badge scale-status-badge"></span>
                            <small class="row-meta">Saved records keep this mark snapshot even if you later hide or reweight it.</small>
                          </div>
                        </div>
                      <% }) %>
                    </div>
                  </article>
                <% }) %>
              </div>
            </section>

            <div class="form-actions">
              <button type="submit" class="btn-primary">Save Customization</button>
            </div>
          </form>
        </article>

        <script id="teacherCustomizationState" type="application/json"><%- JSON.stringify({
          defaultGradingScaleSet,
          selectedGradingScaleSet: selectedScaleSet
        }) %></script>
      <% } %>
    <% } %>
  </section>
</main>

<script src="/js/teacher-customization.js"></script>

<%- include('../partials/teacherFooter') %>
