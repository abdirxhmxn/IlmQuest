<%
  const resolvedPageTitle = typeof pageTitle === "string" && pageTitle.trim().length
    ? pageTitle.trim()
    : "IlmQuest";
  const resolvedPageStyles = (typeof pageStyles !== "undefined" && Array.isArray(pageStyles)) ? pageStyles : [];
  if (typeof pageStyles !== "undefined" && !Array.isArray(pageStyles)) {
    console.warn("[IlmQuest] header.ejs: pageStyles is not an array — got:", typeof pageStyles);
  }
%>
<%# Public marketing header shell: loads global style architecture + landing-specific styles. %>
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title><%= resolvedPageTitle %></title>
<link rel="icon" type="image/png" sizes="32x32" href="<%= assetUrl('/imgs/logo.png') %>" />
<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://api.fontshare.com" />
<link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&display=swap" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&family=Amiri:wght@400;700&display=swap" />
<!-- Foundation -->
<link rel="stylesheet" href="<%= assetUrl('/css/tokens.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/reset.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/base.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/a11y.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/glass.css') %>" />
<!-- Components -->
<link rel="stylesheet" href="<%= assetUrl('/css/components/typography.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/buttons.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/forms.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/badges.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/cards.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/tables.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/modals.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/drawers.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/toasts.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/tabs.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/navigation.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/empty-state.css') %>" />
<link rel="stylesheet" href="<%= assetUrl('/css/components/loading.css') %>" />
<!-- Shell -->
<link rel="stylesheet" href="<%= assetUrl('/css/shells/platform-shell.css') %>" />
<!-- Page -->
<% resolvedPageStyles.forEach((styleHref) => { %>
  <link rel="stylesheet" href="<%= assetUrl(styleHref) %>" />
<% }) %>
<script src="<%= assetUrl('/js/nav-toggle.js') %>" defer></script>
</head>

<body>
  <header class="site-header">
    <div class="brand">
      <img src="<%= assetUrl('/imgs/finalLogo.jpg') %>" alt="IlmQuest logo" class="logo-img">
      <a href="/" class="brand-name">IlmQuest</a>
    </div>
    <div class="header-right">
      <button
        type="button"
        class="nav-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="public-nav"
        data-nav-toggle
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
      <nav class="nav-links header-nav" id="public-nav" data-nav-menu>
        <a href="/login" class="nav-link">Sign in</a>
        <a href="/login" class="nav-link">School Access</a>
      </nav>
    </div>
  </header>
