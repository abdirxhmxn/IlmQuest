    </div>
  </div>
</div>
<% const resolvedPageScripts = (typeof pageScripts !== "undefined" && Array.isArray(pageScripts)) ? pageScripts : []; %>
<script src="<%= assetUrl('/js/app-shell.js') %>"></script>
<script src="<%= assetUrl('/js/scroll-animations.js') %>" defer></script>
<% resolvedPageScripts.forEach((scriptSrc) => { %>
  <script src="<%= assetUrl(scriptSrc) %>" defer></script>
<% }) %>
</body>
</html>
