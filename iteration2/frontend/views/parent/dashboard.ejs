<%- include('../partials/parentShellStart', {
  pageTitle: 'IlmQuest Parent Portal',
  pageStyles: ['/css/pages/parent-dashboard.css'],
  activePage: activePage || 'dashboard',
  user
}) %>

<%
  const summary = portal || {};
  const children = Array.isArray(summary.childSummaries) ? summary.childSummaries : [];
  const selectedChild = summary.selectedChild || null;
  const selectedChildId = summary.selectedChildId || "";
  const gradesSummary = summary.selectedGradesSummary || {};
  const attendanceSummary = summary.selectedAttendanceSummary || {};
  const missionsSummary = summary.selectedMissionsSummary || {};
  const familySnapshot = summary.familySnapshot || {};
  const paymentSummary = summary.paymentSummary || {};
  const familyBillingSummary = paymentSummary.summary || {};
  const billingProfile = paymentSummary.billingProfile || {};
  const paymentRows = Array.isArray(paymentSummary.historyRows) ? paymentSummary.historyRows : [];
  const upcomingPayments = Array.isArray(paymentSummary.upcomingRows) ? paymentSummary.upcomingRows : [];
  const billingByChild = Array.isArray(paymentSummary.byStudent) ? paymentSummary.byStudent : [];
  const selectedBilling = paymentSummary.selectedChildSummary || {};
  const reports = Array.isArray(summary.recentReports) ? summary.recentReports : [];
  const announcements = Array.isArray(summary.announcements) ? summary.announcements : [];
  const selectedGradeValue = Math.max(0, Math.min(100, Number(selectedChild?.overallAverage || gradesSummary.overallAverage || 0)));
  const selectedAttendanceValue = Math.max(0, Math.min(100, Number(selectedChild?.attendanceRate || attendanceSummary.attendanceRate || 0)));
  const selectedMissionValue = Math.max(0, Math.min(100, Number(missionsSummary.completionRate || 0)));
  const successMessages = Array.isArray(messages?.success) ? messages.success : [];
  const errorMessages = [
    ...(Array.isArray(messages?.error) ? messages.error : []),
    ...(Array.isArray(messages?.errors) ? messages.errors.map((entry) => entry?.msg || entry).filter(Boolean) : [])
  ];
%>

<section class="parent-page-shell parent-dashboard-page">
  <header class="parent-page-header">
    <button
      type="button"
      class="parent-sidebar-toggle"
      data-parent-sidebar-toggle
      aria-controls="parentSidebar"
      aria-label="Toggle sidebar"
      aria-expanded="true"
    >
      Hide Menu
    </button>
    <div class="parent-page-title">
      <h1>Family Dashboard</h1>
      <p>Track child progress, family billing, and the updates that need your attention in one calm view.</p>
    </div>
    <div class="parent-top-actions">
      <a class="parent-action-link" href="/parent/home#payments">View Billing</a>
      <a class="parent-action-link" href="/parent/home#grades">View Grades</a>
      <a class="parent-action-link" href="/parent/home#missions">View Missions</a>
      <% if (selectedChildId) { %>
        <a class="parent-action-link" href="/parent/child/<%= selectedChildId %>">Open Child Progress</a>
      <% } %>
      <% if (selectedChildId) { %>
        <a class="parent-action-link" href="/parent/reports/<%= selectedChildId %>/download">Download Report</a>
      <% } %>
    </div>
  </header>

  <% if (successMessages.length > 0) { %>
    <div class="parent-flash parent-flash-success"><%= successMessages.join(' ') %></div>
  <% } %>
  <% if (errorMessages.length > 0) { %>
    <div class="parent-flash parent-flash-error"><%= errorMessages.join(' ') %></div>
  <% } %>

  <section class="parent-card parent-hero-card">
    <div class="parent-hero-copy">
      <p class="parent-hero-kicker">Family Command Center</p>
      <h2>Welcome back, <%= user?.firstName || 'Parent' %></h2>
      <p>Keep academic progress and payment health visible without jumping between pages or losing child context.</p>
      <div class="parent-hero-meta">
        <span><strong><%= children.length %></strong> linked child account(s)</span>
        <span><strong><%= billingByChild.length %></strong> billing profile<%= billingByChild.length === 1 ? '' : 's' %> tracked</span>
        <span><strong><%= reports.length %></strong> recent report event<%= reports.length === 1 ? '' : 's' %></span>
      </div>
    </div>
    <div class="parent-hero-stats">
      <article>
        <p class="metric-label">Family Avg Grade</p>
        <p class="metric-value"><%= Number.isFinite(Number(familySnapshot.averageGrade)) ? `${Number(familySnapshot.averageGrade).toFixed(1)}%` : 'N/A' %></p>
        <p class="metric-note">Across all linked learners</p>
      </article>
      <article>
        <p class="metric-label">Family Avg Attendance</p>
        <p class="metric-value"><%= Number.isFinite(Number(familySnapshot.averageAttendance)) ? `${Number(familySnapshot.averageAttendance).toFixed(1)}%` : 'N/A' %></p>
        <p class="metric-note">Present, late, and excused sessions</p>
      </article>
      <article>
        <p class="metric-label">Open Balance</p>
        <p class="metric-value"><%= familyBillingSummary.totalOutstandingLabel || '$0.00' %></p>
        <p class="metric-note"><%= familyBillingSummary.statusChip?.label || 'No bills yet' %></p>
      </article>
      <article>
        <p class="metric-label">Missions Completed</p>
        <p class="metric-value"><%= Number(familySnapshot.missionCompleted || 0) %></p>
        <p class="metric-note"><%= Number(familySnapshot.missionAssigned || 0) %> assigned overall</p>
      </article>
    </div>
  </section>

  <section class="parent-dashboard-primary-grid reveal-stagger">
    <article class="parent-card selected-child-panel reveal">
      <header class="section-head section-head-spread">
        <div>
          <h3>Selected Child Overview</h3>
          <p><%= selectedChild ? selectedChild.fullName : 'Choose a child to load details' %></p>
        </div>
        <% if (selectedChildId) { %>
          <a class="parent-action-link parent-action-link-soft" href="/parent/child/<%= selectedChildId %>">Open Full Progress</a>
        <% } %>
      </header>

      <% if (!selectedChild) { %>
        <div class="parent-empty-state">Select a child from the family list to see grades, attendance, missions, and billing at a glance.</div>
      <% } else { %>
        <div class="selected-child-summary-grid">
          <article class="selected-child-card">
            <span class="selected-child-label">Class</span>
            <strong><%= selectedChild.className %></strong>
            <small><%= selectedChild.programType %> · <%= selectedChild.gradeLevel %></small>
          </article>
          <article class="selected-child-card">
            <span class="selected-child-label">Teacher</span>
            <strong><%= selectedChild.teacherNames %></strong>
            <small><%= selectedChild.statusChip?.label || 'In Progress' %></small>
          </article>
          <article class="selected-child-card">
            <span class="selected-child-label">Billing Status</span>
            <strong><%= selectedBilling.statusChip?.label || 'No Bills Yet' %></strong>
            <small><%= selectedBilling.nextDueDateLabel || 'No upcoming balance' %></small>
          </article>
        </div>

        <div class="selected-child-progress-list">
          <article class="selected-progress-card">
            <div class="selected-progress-head">
              <div>
                <p class="metric-label">Overall Grade</p>
                <strong><%= selectedChild.overallAverageLabel %></strong>
              </div>
              <span><%= Math.round(selectedGradeValue) %>%</span>
            </div>
            <progress class="parent-progress" max="100" value="<%= selectedGradeValue %>"></progress>
          </article>

          <article class="selected-progress-card">
            <div class="selected-progress-head">
              <div>
                <p class="metric-label">Attendance Rate</p>
                <strong><%= selectedChild.attendanceRateLabel %></strong>
              </div>
              <span><%= Math.round(selectedAttendanceValue) %>%</span>
            </div>
            <progress class="parent-progress" max="100" value="<%= selectedAttendanceValue %>"></progress>
          </article>

          <article class="selected-progress-card">
            <div class="selected-progress-head">
              <div>
                <p class="metric-label">Mission Completion</p>
                <strong><%= missionsSummary.completionRateLabel || 'N/A' %></strong>
              </div>
              <span><%= Math.round(selectedMissionValue) %>%</span>
            </div>
            <progress class="parent-progress" max="100" value="<%= selectedMissionValue %>"></progress>
          </article>
        </div>
      <% } %>
    </article>

    <aside id="payments" class="parent-card family-billing-panel reveal">
      <header class="section-head section-head-spread">
        <div>
          <h3>Billing Snapshot</h3>
          <p>Review open balances and the next family payment due date.</p>
        </div>
        <span class="status-chip status-<%= familyBillingSummary.statusChip?.tone || 'neutral' %>"><%= familyBillingSummary.statusChip?.label || 'No Bills Yet' %></span>
      </header>

      <div class="billing-stat-grid">
        <article>
          <p class="metric-label">Outstanding</p>
          <p class="metric-value"><%= familyBillingSummary.totalOutstandingLabel || '$0.00' %></p>
          <small class="metric-note"><%= Number(familyBillingSummary.openCount || 0) %> open item<%= Number(familyBillingSummary.openCount || 0) === 1 ? '' : 's' %></small>
        </article>
        <article>
          <p class="metric-label">Collected</p>
          <p class="metric-value"><%= familyBillingSummary.totalPaidLabel || '$0.00' %></p>
          <small class="metric-note"><%= Number(familyBillingSummary.paidCount || 0) %> paid item<%= Number(familyBillingSummary.paidCount || 0) === 1 ? '' : 's' %></small>
        </article>
        <article>
          <p class="metric-label">Overdue</p>
          <p class="metric-value"><%= familyBillingSummary.overdueAmountLabel || '$0.00' %></p>
          <small class="metric-note"><%= Number(familyBillingSummary.overdueCount || 0) %> overdue</small>
        </article>
        <article>
          <p class="metric-label">Billing Day</p>
          <p class="metric-value">Day <%= Number(billingProfile.billingDayOfMonth || 1) %></p>
          <small class="metric-note"><%= billingProfile.monthlyTuitionAmountLabel || '$0.00' %> monthly profile</small>
        </article>
      </div>

      <div class="billing-office-note">
        <strong>Need to act on a balance?</strong>
        <p>Online payment processing is not enabled in the portal yet. Use the references below when following up with your school office.</p>
      </div>

      <% if (!upcomingPayments.length) { %>
        <div class="parent-empty-state">No upcoming billing items are scheduled right now.</div>
      <% } else { %>
        <div class="billing-upcoming-list">
          <% upcomingPayments.forEach((row) => { %>
            <article class="billing-upcoming-item">
              <div>
                <h4><%= row.studentName %></h4>
                <p><%= row.title %> · <%= row.category %></p>
              </div>
              <div class="billing-upcoming-meta">
                <strong><%= row.balanceLabel %></strong>
                <span><%= row.dueDateLabel %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </aside>
  </section>

  <section class="parent-shell-grid-2 parent-overview-grid">
    <section class="parent-card section-card">
      <header class="section-head">
        <h3>Recent Updates</h3>
        <p>Pinned and recently published school updates relevant to your family.</p>
      </header>
      <% if (!announcements.length) { %>
        <div class="parent-empty-state">No announcements are available right now.</div>
      <% } else { %>
        <div class="parent-announcement-list">
          <% announcements.forEach((item) => { %>
            <article class="parent-announcement-item">
              <div class="parent-announcement-head">
                <h4><%= item.title %></h4>
                <% if (item.isPinned) { %><span class="status-chip status-success">Pinned</span><% } %>
              </div>
              <p><%= item.summary || item.content || '' %></p>
              <small>Published <%= item.publishLabel || item.createdAtLabel %></small>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section id="children" class="parent-card child-switcher-card">
      <header class="section-head">
        <h3>Children</h3>
        <p>Switch child context to view detailed read-only progress.</p>
      </header>
      <% if (children.length === 0) { %>
        <div class="parent-empty-state">No children are linked to this parent account yet. Please contact your school admin.</div>
      <% } else { %>
        <div class="child-card-grid">
          <% children.forEach((child) => { %>
            <a href="/parent/home?childId=<%= child.childId %>" class="child-card <%= child.childId === selectedChildId ? 'active' : '' %>">
              <div class="child-card-top">
                <h4><%= child.fullName %></h4>
                <span class="status-chip status-<%= child.statusChip?.tone || 'neutral' %>"><%= child.statusChip?.label || 'In Progress' %></span>
              </div>
              <p><strong>Class:</strong> <%= child.className %></p>
              <p><strong>Program:</strong> <%= child.programType %> · <%= child.gradeLevel %></p>
              <div class="child-card-metrics">
                <span>Grade <strong><%= child.overallAverageLabel %></strong></span>
                <span>Attendance <strong><%= child.attendanceRateLabel %></strong></span>
              </div>
              <div class="child-card-billing">
                <span><%= child.billing?.totalOutstandingLabel || '$0.00' %></span>
                <small><%= child.billing?.nextDueDateLabel || 'No upcoming balance' %></small>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>
    </section>
  </section>

  <section class="parent-shell-grid-2 parent-summary-grid">
    <article class="parent-card summary-card">
      <header class="section-head">
        <h3>Academic Summary</h3>
        <p><%= selectedChild ? selectedChild.fullName : 'No child selected' %></p>
      </header>
      <% if (!selectedChild) { %>
        <div class="parent-empty-state">Select a child to view academic details.</div>
      <% } else { %>
        <dl class="summary-list">
          <div><dt>Overall Grade</dt><dd><%= selectedChild.overallAverageLabel %></dd></div>
          <div><dt>Class</dt><dd><%= selectedChild.className %></dd></div>
          <div><dt>Teacher</dt><dd><%= selectedChild.teacherNames %></dd></div>
          <div><dt>Attendance</dt><dd><%= selectedChild.attendanceRateLabel %></dd></div>
        </dl>
      <% } %>
    </article>

    <article class="parent-card summary-card">
      <header class="section-head">
        <h3>Billing By Child</h3>
        <p>Keep each learner&apos;s payment status easy to compare.</p>
      </header>
      <% if (!billingByChild.length) { %>
        <div class="parent-empty-state">No billing records are available for linked children yet.</div>
      <% } else { %>
        <div class="billing-by-child-list">
          <% billingByChild.forEach((entry) => { %>
            <article class="billing-child-row">
              <div>
                <h4><%= entry.studentName %></h4>
                <p><%= entry.nextDueDateLabel || 'No upcoming balance' %></p>
              </div>
              <div class="billing-child-meta">
                <strong><%= entry.totalOutstandingLabel || '$0.00' %></strong>
                <span class="status-chip status-<%= entry.statusChip?.tone || 'neutral' %>"><%= entry.statusChip?.label || 'No Bills Yet' %></span>
              </div>
            </article>
          <% }) %>
        </div>
      <% } %>
    </article>
  </section>

  <section class="parent-card section-card payment-history-card reveal">
    <header class="section-head">
      <h3>Payment History</h3>
      <p>Recent family billing records with status and outstanding balance references.</p>
    </header>
    <% if (!paymentRows.length) { %>
      <div class="parent-empty-state">No payment activity is available for this family yet.</div>
    <% } else { %>
      <div class="table-wrap">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Charge</th>
              <th>Due</th>
              <th>Status</th>
              <th>Expected</th>
              <th>Paid</th>
              <th>Balance</th>
            </tr>
          </thead>
          <tbody>
            <% paymentRows.forEach((row) => { %>
              <tr>
                <td>
                  <strong><%= row.studentName %></strong>
                  <div class="table-meta"><%= row.category %></div>
                </td>
                <td>
                  <strong><%= row.title %></strong>
                  <div class="table-meta"><%= row.receiptReference || row.method || 'School office reference pending' %></div>
                </td>
                <td><%= row.dueDateLabel %></td>
                <td><span class="status-chip status-<%= row.statusKey || 'neutral' %>"><%= row.statusLabel %></span></td>
                <td><%= row.expectedAmountLabel %></td>
                <td><%= row.paidAmountLabel %></td>
                <td><strong><%= row.balanceLabel %></strong></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <section id="grades" class="parent-card section-card reveal">
    <header class="section-head">
      <h3>Grades</h3>
      <p>Subject-level performance and latest teacher feedback.</p>
    </header>
    <% if (!selectedChild || !Array.isArray(gradesSummary.subjectRows) || gradesSummary.subjectRows.length === 0) { %>
      <div class="parent-empty-state">No grades are available for the selected child yet.</div>
    <% } else { %>
      <div class="table-wrap">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Subject</th>
              <th>Average</th>
              <th>Teacher Comment</th>
            </tr>
          </thead>
          <tbody>
            <% gradesSummary.subjectRows.forEach((row) => { %>
              <tr>
                <td><%= row.subject %></td>
                <td><strong><%= row.averageLabel %></strong></td>
                <td><%= row.teacherComment || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>

  <section class="parent-shell-grid-2 parent-detail-grid reveal-stagger">
    <section id="attendance" class="parent-card section-card reveal">
      <header class="section-head">
        <h3>Attendance</h3>
        <p>Absence, excused, and late-arrival breakdown.</p>
      </header>
      <% if (!selectedChild) { %>
        <div class="parent-empty-state">Select a child to view attendance details.</div>
      <% } else { %>
        <div class="attendance-summary-grid">
          <article>
            <p class="metric-label">Attendance Rate</p>
            <p class="metric-value"><%= Number.isFinite(Number(attendanceSummary.attendanceRate)) ? `${Number(attendanceSummary.attendanceRate).toFixed(1)}%` : 'N/A' %></p>
          </article>
          <article>
            <p class="metric-label">Absences</p>
            <p class="metric-value"><%= attendanceSummary.absences || 0 %></p>
          </article>
          <article>
            <p class="metric-label">Excused</p>
            <p class="metric-value"><%= attendanceSummary.excused || 0 %></p>
          </article>
          <article>
            <p class="metric-label">Late Arrivals</p>
            <p class="metric-value"><%= attendanceSummary.late || 0 %></p>
          </article>
        </div>
      <% } %>
    </section>

    <section id="reports" class="parent-card section-card reveal">
      <header class="section-head">
        <h3>Reports</h3>
        <p>Download child reports and review recent report activity.</p>
      </header>
      <% if (selectedChildId) { %>
        <a class="parent-action-link report-download-link" href="/parent/reports/<%= selectedChildId %>/download">
          Download Latest Report for Selected Child
        </a>
      <% } %>
      <% if (reports.length === 0) { %>
        <div class="parent-empty-state">No report activity is available yet.</div>
      <% } else { %>
        <ul class="report-list">
          <% reports.forEach((entry) => { %>
            <li>
              <span><strong><%= entry.studentName %></strong></span>
              <span><%= entry.generatedAtLabel %></span>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </section>
  </section>

  <section id="missions" class="parent-card section-card reveal">
    <header class="section-head">
      <h3>Missions</h3>
      <p>Read-only mission progress for the selected child.</p>
    </header>
    <% if (!selectedChild || !Array.isArray(missionsSummary.rows) || missionsSummary.rows.length === 0) { %>
      <div class="parent-empty-state">No mission records are available for the selected child yet.</div>
    <% } else { %>
      <div class="table-wrap">
        <table class="portal-table">
          <thead>
            <tr>
              <th>Mission</th>
              <th>Type</th>
              <th>Category</th>
              <th>XP</th>
              <th>Due</th>
              <th>Status</th>
              <th>Updated</th>
            </tr>
          </thead>
          <tbody>
            <% missionsSummary.rows.forEach((row) => { %>
              <tr>
                <td><%= row.title %></td>
                <td><%= row.type %></td>
                <td><%= row.category %></td>
                <td><%= Number(row.pointsXP || 0) %></td>
                <td><%= row.dueDateLabel %></td>
                <td><span class="status-chip status-<%= String(row.status || '').toLowerCase() %>"><%= row.status %></span></td>
                <td><%= row.updatedAtLabel %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</section>

<%- include('../partials/parentShellEnd') %>
