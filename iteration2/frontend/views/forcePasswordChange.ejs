<%- include('partials/header') -%>

<link rel="stylesheet" href="/css/pages/auth-shell.css" />

<main class="auth-page auth-page-login">
  <section class="auth-layout" aria-labelledby="force-password-title">
    <%- include('partials/authBrandPanel', {
      eyebrow: 'SECURITY CHECK',
      headingTop: 'Protect your',
      headingAccent: 'learning portal',
      supportingText: "Before you continue, update your temporary password to secure your account and protect student data."
    }) %>

    <section class="auth-form-panel">
      <div class="auth-form-wrap">
        <header class="auth-form-header">
          <h1 id="force-password-title">Update your password</h1>
          <p>This step is required before you can access your dashboard.</p>
        </header>

        <% if (messages && (messages.errors || messages.info || messages.success)) { %>
          <div class="flash-messages" role="status" aria-live="polite">
            <% if (messages.errors) { %>
              <% messages.errors.forEach(msg => { %>
                <div class="flash-message flash-error"><%= msg.msg %></div>
              <% }) %>
            <% } %>
            <% if (messages.info) { %>
              <% messages.info.forEach(msg => { %>
                <div class="flash-message flash-info"><%= msg.msg %></div>
              <% }) %>
            <% } %>
            <% if (messages.success) { %>
              <% messages.success.forEach(msg => { %>
                <div class="flash-message flash-info"><%= msg.msg %></div>
              <% }) %>
            <% } %>
          </div>
        <% } %>

        <form action="/force-password-change?_method=PUT" method="POST" class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="form-group auth-field">
            <label for="new-password" class="form-label auth-label">New Password</label>
            <div class="auth-field-control">
              <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="auth-icon"><rect x="5" y="10" width="14" height="10" rx="2"></rect><path d="M8 10V7a4 4 0 1 1 8 0v3"></path></svg>
              </span>
              <input
                type="password"
                id="new-password"
                name="new-password"
                class="form-input auth-input"
                placeholder="At least 8 characters"
                autocomplete="new-password"
                required
              />
            </div>
          </div>

          <div class="form-group auth-field">
            <label for="confirm-password" class="form-label auth-label">Confirm New Password</label>
            <div class="auth-field-control">
              <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="auth-icon"><path d="M3 6h18v12H3z"></path><path d="m3 7 9 7 9-7"></path></svg>
              </span>
              <input
                type="password"
                id="confirm-password"
                name="confirm-password"
                class="form-input auth-input"
                placeholder="Re-enter your new password"
                autocomplete="new-password"
                required
              />
            </div>
          </div>

          <button type="submit" class="submit-btn auth-submit">
            Save and Continue
            <svg viewBox="0 0 24 24" class="auth-icon" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
          </button>
        </form>

        <p class="auth-switch-link">
          Need a different account?
          <a href="/logout">Sign out</a>
        </p>
      </div>
    </section>
  </section>
</main>

<%- include('partials/footer') -%>
