<%# Admin dashboard view: three-column analytical layout with KPI row, insight cards, and utility rail. %>
<%- include('../partials/adminShellStart', {
  pageTitle: 'IlmQuest Admin Dashboard',
  pageStyles: ['/css/pages/admin-dashboard.css'],
  activePage: activePage || 'dashboard',
  user
}) %>

<%
  const icon = typeof iconSvg === 'function' ? iconSvg : (() => '');
  const fmtNumber = (value) => new Intl.NumberFormat('en-US').format(Number(value || 0));

  const metrics = adminMetrics || {};
  const totalStudents = Number.isFinite(Number(metrics.totalStudents)) ? Number(metrics.totalStudents) : (Array.isArray(students) ? students.length : 0);
  const totalClasses = Number.isFinite(Number(metrics.totalClasses)) ? Number(metrics.totalClasses) : (Array.isArray(classes) ? classes.length : 0);
  const activeClasses = Number.isFinite(Number(metrics.activeClasses))
    ? Number(metrics.activeClasses)
    : (Array.isArray(classes) ? classes.filter((cls) => cls && cls.active !== false).length : 0);
  const totalTeachers = Number.isFinite(Number(metrics.totalTeachers)) ? Number(metrics.totalTeachers) : (Array.isArray(teachers) ? teachers.length : 0);
  const totalParents = Number.isFinite(Number(metrics.totalParents)) ? Number(metrics.totalParents) : (Array.isArray(parents) ? parents.length : 0);

  const attendanceRate = Number.isFinite(Number(metrics.attendanceRate)) ? Number(metrics.attendanceRate) : null;
  const averageGrade = Number.isFinite(Number(metrics.averageGrade)) ? Number(metrics.averageGrade) : null;

  const smartAlerts = Array.isArray(metrics.alerts) && metrics.alerts.length
    ? metrics.alerts
    : [{ tone: 'info', title: 'No urgent alerts', detail: 'Real-time alerts will appear here as new attendance, grade, and mission signals arrive.' }];

  const topStudents = Array.isArray(metrics.topStudents) ? metrics.topStudents : [];
  const bottomStudents = Array.isArray(metrics.bottomStudents) ? metrics.bottomStudents : [];
  const topClasses = Array.isArray(metrics.topClasses) ? metrics.topClasses : [];
  const bottomClasses = Array.isArray(metrics.bottomClasses) ? metrics.bottomClasses : [];

  const successMessages = Array.isArray(messages?.success) ? messages.success : [];
  const errorMessages = [
    ...(Array.isArray(messages?.error) ? messages.error : []),
    ...(Array.isArray(messages?.errors) ? messages.errors.map((entry) => entry?.msg || entry).filter(Boolean) : [])
  ];

  // Maps alert tone to a stable icon so warning semantics stay consistent in the utility rail.
  function toneIconName(tone) {
    if (tone === 'critical') return 'reports';
    if (tone === 'warning') return 'attendance';
    return 'reports';
  }

  // Normalizes percent labels from mixed data sources and protects against missing values.
  function pctLabel(value, digits = 1) {
    if (!Number.isFinite(Number(value))) return 'N/A';
    return `${Number(value).toFixed(digits)}%`;
  }

  // Grade rows use a unified numeric format to avoid visual jitter in dense tables.
  function rowGradeLabel(value) {
    return Number.isFinite(Number(value)) ? `${Number(value).toFixed(1)}%` : 'N/A';
  }

  const programDistribution = Array.isArray(metrics.programDistribution) ? metrics.programDistribution : [];
  const dashboardAnnouncements = Array.isArray(adminAnnouncements) ? adminAnnouncements : [];
%>

<header class="dashboard-topbar admin-page-header">
  <button
    type="button"
    class="sidebar-toggle"
    data-sidebar-toggle
    aria-label="Toggle sidebar"
    aria-expanded="false"
    aria-controls="adminSidebar"
  >
    <%- icon('menu') %>
  </button>
  <div class="admin-page-title">
    <p class="admin-breadcrumbs">Admin / Dashboard / Overview</p>
    <h1>Dashboard Overview</h1>
    <p>Monitor enrollment, classroom performance, and engagement health from one command surface.</p>
  </div>
  <div class="admin-icon-actions" aria-hidden="true">
    <button class="admin-icon-btn" type="button" tabindex="-1"><%- icon('activity') %></button>
    <button class="admin-icon-btn" type="button" tabindex="-1"><%- icon('bell') %></button>
  </div>
  <div class="topbar-actions admin-top-actions">
    <a class="ghost-action admin-action-link" href="/admin/users">Manage Users</a>
    <a class="ghost-action admin-action-link" href="/admin/classes">Manage Classes</a>
    <a class="ghost-action admin-action-link" href="/admin/reports">Reports</a>
  </div>
</header>

<% if (successMessages.length > 0) { %>
  <div class="admin-flash admin-flash-success"><%= successMessages.join(' ') %></div>
<% } %>
<% if (errorMessages.length > 0) { %>
  <div class="admin-flash admin-flash-error"><%= errorMessages.join(' ') %></div>
<% } %>

<section class="dashboard-shell admin-page-grid">
  <div class="admin-main-column">
    <section class="kpi-grid" aria-label="KPI summary">
      <article class="kpi-card">
        <div class="kpi-card-head">
          <p class="kpi-label">TOTAL STUDENTS</p>
          <span class="kpi-icon"><%- icon('students') %></span>
        </div>
        <p class="kpi-value"><%= fmtNumber(totalStudents) %></p>
        <p class="kpi-meta">Across <%= fmtNumber(totalClasses) %> classes</p>
      </article>

      <article class="kpi-card accent-success">
        <div class="kpi-card-head">
          <p class="kpi-label">ACTIVE CLASSES</p>
          <span class="kpi-icon"><%- icon('classes') %></span>
        </div>
        <p class="kpi-value"><%= fmtNumber(activeClasses) %></p>
        <p class="kpi-meta">All running cohorts</p>
      </article>

      <article class="kpi-card">
        <div class="kpi-card-head">
          <p class="kpi-label">TOTAL TEACHERS</p>
          <span class="kpi-icon"><%- icon('reports') %></span>
        </div>
        <p class="kpi-value"><%= fmtNumber(totalTeachers) %></p>
        <p class="kpi-meta">Instruction team members</p>
      </article>

      <article class="kpi-card accent-critical">
        <div class="kpi-card-head">
          <p class="kpi-label">TOTAL PARENTS</p>
          <span class="kpi-icon"><%- icon('announcements') %></span>
        </div>
        <p class="kpi-value"><%= fmtNumber(totalParents) %></p>
        <p class="kpi-meta">Guardian accounts linked to students</p>
      </article>

      <article class="kpi-card accent-warning" id="attendance-rate">
        <div class="kpi-card-head">
          <p class="kpi-label">ATTENDANCE RATE</p>
          <span class="kpi-icon"><%- icon('attendance') %></span>
        </div>
        <p class="kpi-value"><%= pctLabel(attendanceRate) %></p>
        <p class="kpi-meta">All attendance records</p>
      </article>

      <article class="kpi-card">
        <div class="kpi-card-head">
          <p class="kpi-label">AVERAGE GRADE</p>
          <span class="kpi-icon"><%- icon('reports') %></span>
        </div>
        <p class="kpi-value"><%= pctLabel(averageGrade) %></p>
        <p class="kpi-meta">Across recorded assessments</p>
      </article>
    </section>

    <section class="overview-mosaic" id="performance-intelligence">
      <article class="section-card compact-card insight-wide">
        <header class="section-card-header">
          <h3><span class="inline-section-icon"><%- icon('reports') %></span> Top 5 Students</h3>
        </header>
        <div class="table-shell">
          <table class="metrics-table">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Student</th>
                <th>Class</th>
                <th>Grade</th>
                <th>XP</th>
              </tr>
            </thead>
            <tbody>
              <% if (topStudents.length === 0) { %>
                <tr><td colspan="5" class="empty-row">No student grade data available yet.</td></tr>
              <% } %>
              <% topStudents.forEach((row, index) => { %>
                <tr>
                  <td><span class="rank-badge rank-top">#<%= index + 1 %></span></td>
                  <td class="strong-cell"><%= row.name %></td>
                  <td><%= row.className %></td>
                  <td class="grade-positive"><%= rowGradeLabel(row.avgGrade) %></td>
                  <td class="mono-cell"><%= fmtNumber(row.points || 0) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>

      <article class="section-card compact-card">
        <header class="section-card-header">
          <h3><span class="inline-section-icon"><%- icon('classes') %></span> Top 3 Classes</h3>
        </header>
        <div class="table-shell">
          <table class="metrics-table">
            <thead>
              <tr>
                <th>Class</th>
                <th>Avg Grade</th>
                <th>Attendance</th>
                <th>Points</th>
              </tr>
            </thead>
            <tbody>
              <% if (topClasses.length === 0) { %>
                <tr><td colspan="4" class="empty-row">No class performance data available yet.</td></tr>
              <% } %>
              <% topClasses.forEach((row) => { %>
                <tr>
                  <td class="strong-cell"><%= row.className %></td>
                  <td class="grade-positive"><%= rowGradeLabel(row.avgGrade) %></td>
                  <td class="grade-positive"><%= pctLabel(row.attendanceRate) %></td>
                  <td class="mono-cell"><%= fmtNumber(row.points || 0) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>

      <article class="section-card compact-card">
        <header class="section-card-header">
          <h3><span class="inline-section-icon"><%- icon('attendance') %></span> Bottom 5 Students</h3>
        </header>
        <div class="table-shell">
          <table class="metrics-table">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Student</th>
                <th>Class</th>
                <th>Grade</th>
                <th>XP</th>
              </tr>
            </thead>
            <tbody>
              <% if (bottomStudents.length === 0) { %>
                <tr><td colspan="5" class="empty-row">No low-performing rows yet.</td></tr>
              <% } %>
              <% bottomStudents.forEach((row, index) => { %>
                <tr>
                  <td><span class="rank-badge rank-bottom">#<%= totalStudents - index %></span></td>
                  <td class="strong-cell"><%= row.name %></td>
                  <td><%= row.className %></td>
                  <td class="grade-negative"><%= rowGradeLabel(row.avgGrade) %></td>
                  <td class="mono-cell"><%= fmtNumber(row.points || 0) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>

      <article class="section-card compact-card insight-wide">
        <header class="section-card-header">
          <h3><span class="inline-section-icon"><%- icon('classes') %></span> Bottom 3 Classes</h3>
        </header>
        <div class="table-shell">
          <table class="metrics-table">
            <thead>
              <tr>
                <th>Class</th>
                <th>Avg Grade</th>
                <th>Attendance</th>
                <th>Points</th>
              </tr>
            </thead>
            <tbody>
              <% if (bottomClasses.length === 0) { %>
                <tr><td colspan="4" class="empty-row">No underperforming classes found.</td></tr>
              <% } %>
              <% bottomClasses.forEach((row) => { %>
                <tr>
                  <td class="strong-cell"><%= row.className %></td>
                  <td class="grade-negative"><%= rowGradeLabel(row.avgGrade) %></td>
                  <td class="grade-warning"><%= pctLabel(row.attendanceRate) %></td>
                  <td class="mono-cell"><%= fmtNumber(row.points || 0) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </article>
    </section>

  </div>

  <aside class="admin-side-column admin-utility-rail">
    <section class="section-card" id="smart-alerts">
      <header class="section-card-header">
        <h2><span class="inline-section-icon"><%- icon('announcements') %></span> Smart Alerts</h2>
        <span class="active-badge"><%= smartAlerts.length %> active</span>
      </header>
      <div class="alerts-list">
        <% smartAlerts.forEach((alert) => { %>
          <article class="alert-item tone-<%= alert.tone || 'info' %>">
            <div class="alert-left">
              <div class="alert-icon-wrap"><%- icon(toneIconName(alert.tone)) %></div>
              <div>
                <p class="alert-title"><%= alert.title %></p>
                <p class="alert-detail"><%= alert.detail %></p>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="section-card section-mini" id="admin-announcements">
      <header class="section-card-header">
        <h3><span class="inline-section-icon"><%- icon('announcements') %></span> Announcements</h3>
        <a class="admin-mini-link" href="/admin/announcements">Manage</a>
      </header>
      <div class="mini-announcement-list">
        <% if (dashboardAnnouncements.length === 0) { %>
          <p class="distribution-empty">No published announcements yet.</p>
        <% } %>
        <% dashboardAnnouncements.forEach((item) => { %>
          <article class="mini-announcement-item">
            <div class="mini-announcement-head">
              <strong><%= item.title %></strong>
              <% if (item.isPinned) { %><span class="status-badge status-paid">Pinned</span><% } %>
            </div>
            <p><%= item.summary || item.content || '' %></p>
            <span class="mini-announcement-date">Published <%= item.publishLabel || item.createdAtLabel %></span>
          </article>
        <% }) %>
      </div>
    </section>

    <section class="section-card section-mini" id="admin-distribution">
      <header class="section-card-header">
        <h3><span class="inline-section-icon"><%- icon('students') %></span> Student Distribution</h3>
      </header>
      <div class="distribution-list">
        <% if (programDistribution.length === 0) { %>
          <p class="distribution-empty">No program distribution available yet.</p>
        <% } %>
        <% programDistribution.forEach((entry) => { %>
          <div class="distribution-row">
            <span><%= entry.program %></span>
            <strong><%= fmtNumber(entry.count) %></strong>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="dashboard-footnote">
      <p>Live totals: <strong><%= totalStudents %></strong> students, <strong><%= totalTeachers %></strong> teachers, <strong><%= totalParents %></strong> parents.</p>
      <a href="/logout" class="logout-link">Logout</a>
    </section>
  </aside>
</section>

<%- include('../partials/adminShellEnd') %>
