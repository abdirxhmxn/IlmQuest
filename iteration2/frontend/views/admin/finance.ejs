<%# Admin finance view: cashflow KPIs, ledger operations, reconciliation, and bank-sync controls. %>
<%- include('../partials/adminShellStart', {
  pageTitle: 'IlmQuest Admin Finance',
  pageStyles: ['/css/pages/admin-finance.css'],
  activePage: activePage || 'finance',
  user
}) %>

<%
  const icon = typeof iconSvg === 'function' ? iconSvg : (() => '');
  const payload = financePage || {};
  const finance = payload.finance || {};
  const summary = finance.summary || {};
  const entries = finance.entries || {};
  const categories = finance.categories || {};
  const bank = finance.bank || {};
  const parentPayments = payload.parentPayments || {};
  const parentPaymentSummary = parentPayments.summary || {};
  const parentPaymentRows = Array.isArray(parentPayments.rows) ? parentPayments.rows : [];
  const overduePaymentRows = Array.isArray(parentPayments.overdueRows) ? parentPayments.overdueRows : [];
  const upcomingPaymentRows = Array.isArray(parentPayments.upcomingRows) ? parentPayments.upcomingRows : [];
  const monthLabel = finance.monthLabel || new Date().toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

  const studentsForForm = Array.isArray(payload.studentsForForm) ? payload.studentsForForm : [];
  const classesForForm = Array.isArray(payload.classesForForm) ? payload.classesForForm : [];
  const entryRows = Array.isArray(entries.rows) ? entries.rows : [];
  const unmatchedRows = Array.isArray(bank.unmatchedRows) ? bank.unmatchedRows : [];
  const connections = Array.isArray(bank.connections) ? bank.connections : [];
  const revenueBreakdown = Array.isArray(finance.revenueBreakdown) ? finance.revenueBreakdown : [];
  const entryMatchOptions = Array.isArray(entries.matchOptions) ? entries.matchOptions : [];

  const providerSummary = providerStatus || {};
  const successMessages = Array.isArray(messages?.success) ? messages.success : [];
  const errorMessages = [
    ...(Array.isArray(messages?.error) ? messages.error : []),
    ...(Array.isArray(messages?.errors) ? messages.errors.map((entry) => entry?.msg || entry).filter(Boolean) : [])
  ];
  const headerActions = [
    { href: '/admin/home', label: 'Dashboard' },
    { href: '/admin/users', label: 'Manage Users' },
    { href: '/admin/reports', label: 'Reports' }
  ];
%>

<%- include('../partials/adminPageHeader', {
  user: typeof user !== 'undefined' ? user : undefined,
  iconSvg: typeof iconSvg === 'function' ? iconSvg : undefined,
  showSidebarToggle: true,
  headerBreadcrumbs: 'Admin / Operations / Finance',
  headerTitle: 'Finance Command Center',
  headerSubtitle: 'Track income, expenses, bank sync health, and reconciliation in one view.',
  headerActions
}) %>

<% if (successMessages.length > 0) { %>
  <div class="admin-flash admin-flash-success"><%= successMessages.join(' ') %></div>
<% } %>
<% if (errorMessages.length > 0) { %>
  <div class="admin-flash admin-flash-error"><%= errorMessages.join(' ') %></div>
<% } %>

<section class="finance-kpi-grid" data-finance-summary-root>
  <article class="finance-kpi-card">
    <p class="finance-kpi-label">Income (<%= monthLabel %>)</p>
    <p class="finance-kpi-value" id="financeMonthlyIncomeValue"><%= summary.monthlyIncomeLabel || '$0.00' %></p>
    <p class="finance-kpi-meta">Manual + bank-imported income entries</p>
  </article>
  <article class="finance-kpi-card">
    <p class="finance-kpi-label">Expenses (<%= monthLabel %>)</p>
    <p class="finance-kpi-value" id="financeMonthlyExpenseValue"><%= summary.monthlyExpenseLabel || '$0.00' %></p>
    <p class="finance-kpi-meta">Posted expense entries</p>
  </article>
  <article class="finance-kpi-card">
    <p class="finance-kpi-label">Net Cash Flow</p>
    <p class="finance-kpi-value <%= Number(summary.netCashFlow || 0) >= 0 ? 'is-positive' : 'is-negative' %>" id="financeNetCashFlowValue"><%= summary.netCashFlowLabel || '$0.00' %></p>
    <p class="finance-kpi-meta">Month-to-date net</p>
  </article>
  <article class="finance-kpi-card">
    <p class="finance-kpi-label">Ledger Entries</p>
    <p class="finance-kpi-value" id="financeEntryCountValue"><%= Number(entryRows.length || 0) %></p>
    <p class="finance-kpi-meta">Rows currently loaded in ledger view</p>
  </article>
  <article class="finance-kpi-card">
    <p class="finance-kpi-label">Reconciliation</p>
    <p class="finance-kpi-value"><span id="financeUnmatchedCountValue"><%= Number(summary.unmatchedCount || 0) %></span> unmatched</p>
    <p class="finance-kpi-meta"><span id="financeMatchedCountValue"><%= Number(summary.matchedCount || 0) %></span> matched</p>
  </article>
  <article class="finance-kpi-card">
    <p class="finance-kpi-label">Last Bank Sync</p>
    <p class="finance-kpi-value" id="financeLastSyncAtValue"><%= summary.lastSyncAtLabel || 'Never' %></p>
    <p class="finance-kpi-meta" id="financeLastSyncStatusValue"><%= summary.lastSyncStatus || 'never' %> · <%= Number(connections.length || 0) %> connection(s)</p>
  </article>
</section>

<section class="finance-page-grid admin-page-grid">
  <div class="admin-main-column">
    <article class="finance-card" id="income-expenses">
      <header class="finance-card-header">
        <h2>Add Income / Expense Entry</h2>
        <p>Manual ledger entry with tenant-safe linking and reconciliation-ready fields.</p>
      </header>
      <datalist id="financeIncomeCategories">
        <% (categories.income || []).forEach((row) => { %>
          <option value="<%= row.label %>"><%= row.label %></option>
        <% }) %>
      </datalist>
      <datalist id="financeExpenseCategories">
        <% (categories.expense || []).forEach((row) => { %>
          <option value="<%= row.label %>"><%= row.label %></option>
        <% }) %>
      </datalist>
      <form class="stacked-form" action="/admin/finance/entries" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-grid-three">
          <label>
            <span>Entry Type</span>
            <select name="entryType" id="financeEntryType" required>
              <option value="income">Income</option>
              <option value="expense">Expense</option>
            </select>
          </label>
          <label>
            <span>Category Label</span>
            <input type="text" name="categoryLabel" id="financeEntryCategory" list="financeIncomeCategories" required />
          </label>
          <label>
            <span>Amount</span>
            <input type="number" name="amount" min="0.01" step="0.01" required />
          </label>
        </div>
        <div class="form-grid-three">
          <label>
            <span>Date</span>
            <input type="date" name="occurredAt" required />
          </label>
          <label>
            <span>Status</span>
            <select name="status">
              <option value="posted">Posted</option>
              <option value="pending">Pending</option>
              <option value="void">Void</option>
            </select>
          </label>
          <label>
            <span>Source</span>
            <select name="source">
              <option value="manual">Manual</option>
              <option value="imported">Imported</option>
              <option value="bank_sync">Bank Sync</option>
            </select>
          </label>
        </div>
        <div class="form-grid-three">
          <label>
            <span>Payer / Vendor</span>
            <input type="text" name="vendorOrPayer" maxlength="160" />
          </label>
          <label>
            <span>Reference</span>
            <input type="text" name="reference" maxlength="160" />
          </label>
          <label>
            <span>Currency</span>
            <input type="text" name="currency" value="USD" maxlength="8" />
          </label>
        </div>
        <div class="form-grid-two">
          <label>
            <span>Linked Student</span>
            <select name="linkedStudentId">
              <option value="">None</option>
              <% studentsForForm.forEach((student) => { %>
                <option value="<%= student.id %>"><%= student.name %></option>
              <% }) %>
            </select>
          </label>
          <label>
            <span>Linked Class</span>
            <select name="linkedClassId">
              <option value="">None</option>
              <% classesForForm.forEach((classDoc) => { %>
                <option value="<%= classDoc.id %>"><%= classDoc.name %></option>
              <% }) %>
            </select>
          </label>
        </div>
        <label>
          <span>Memo</span>
          <textarea name="memo" rows="2" maxlength="500"></textarea>
        </label>
        <button type="submit" class="submit-btn">Create Entry</button>
      </form>
    </article>

    <article class="finance-card" id="entries-ledger">
      <header class="finance-card-header">
        <h2>Income &amp; Expense Ledger</h2>
        <p>Manual and imported entries with category and source tags.</p>
      </header>
      <div class="table-shell">
        <table class="finance-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Category</th>
              <th>Amount</th>
              <th>Date</th>
              <th>Source</th>
              <th>Status</th>
              <th>Memo</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody id="financeEntriesBody">
            <% if (!entryRows.length) { %>
              <tr><td colspan="8" class="empty-row">No finance entries found.</td></tr>
            <% } %>
            <% entryRows.forEach((row) => { %>
              <tr>
                <td><span class="status-chip status-<%= row.entryType === 'income' ? 'paid' : 'due' %>"><%= row.entryTypeLabel %></span></td>
                <td><%= row.categoryLabel %></td>
                <td class="mono-cell"><%= row.amountLabel %></td>
                <td><%= row.dateLabel %></td>
                <td><%= row.source %></td>
                <td><%= row.status %></td>
                <td><%= row.memo || row.reference || '—' %></td>
                <td>
                  <form action="/admin/finance/entries/<%= row.id %>/archive" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <button type="submit" class="table-action">Archive</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>

    <article class="finance-card finance-billing-card" id="parent-billing">
      <header class="finance-card-header">
        <h2>Parent Billing Snapshot</h2>
        <p>School-wide family payment activity with overdue visibility and upcoming balance follow-up.</p>
      </header>

      <div class="finance-billing-summary-grid">
        <article class="finance-billing-stat">
          <span>Invoices</span>
          <strong><%= Number(parentPaymentSummary.invoiceCount || 0) %></strong>
          <p><%= Number(parentPaymentSummary.familyCount || 0) %> family account<%= Number(parentPaymentSummary.familyCount || 0) === 1 ? '' : 's' %></p>
        </article>
        <article class="finance-billing-stat">
          <span>Outstanding</span>
          <strong><%= parentPaymentSummary.totalOutstandingLabel || '$0.00' %></strong>
          <p><%= Number(parentPaymentSummary.openCount || 0) %> open payment<%= Number(parentPaymentSummary.openCount || 0) === 1 ? '' : 's' %></p>
        </article>
        <article class="finance-billing-stat">
          <span>Collected</span>
          <strong><%= parentPaymentSummary.totalCollectedLabel || '$0.00' %></strong>
          <p><%= Number(parentPaymentSummary.paidCount || 0) %> fully paid</p>
        </article>
        <article class="finance-billing-stat">
          <span>Next Due</span>
          <strong><%= parentPaymentSummary.nextDueLabel || 'No upcoming balances' %></strong>
          <p><%= Number(parentPaymentSummary.overdueCount || 0) %> overdue item<%= Number(parentPaymentSummary.overdueCount || 0) === 1 ? '' : 's' %></p>
        </article>
      </div>

      <div class="finance-billing-layout">
        <div class="table-shell">
          <table class="finance-table">
            <thead>
              <tr>
                <th>Family</th>
                <th>Student</th>
                <th>Charge</th>
                <th>Due</th>
                <th>Status</th>
                <th>Expected</th>
                <th>Paid</th>
                <th>Balance</th>
              </tr>
            </thead>
            <tbody>
              <% if (!parentPaymentRows.length) { %>
                <tr><td colspan="8" class="empty-row">No parent billing records are available yet.</td></tr>
              <% } %>
              <% parentPaymentRows.forEach((row) => { %>
                <tr class="<%= row.statusKey === 'overdue' ? 'row-overdue' : '' %>">
                  <td><strong><%= row.parentName %></strong></td>
                  <td><%= row.studentName %></td>
                  <td>
                    <strong class="strong-cell"><%= row.title %></strong>
                    <div class="finance-table-meta"><%= row.category %><%= row.receiptReference ? ` • ${row.receiptReference}` : '' %></div>
                  </td>
                  <td><%= row.dueDateLabel %></td>
                  <td><span class="status-chip status-<%= row.statusKey %>"><%= row.statusLabel %></span></td>
                  <td class="mono-cell"><%= row.expectedAmountLabel %></td>
                  <td class="mono-cell"><%= row.paidAmountLabel %></td>
                  <td class="mono-cell"><strong><%= row.balanceLabel %></strong></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <aside class="finance-billing-rail">
          <section class="finance-billing-side-card">
            <h3>Overdue Follow-up</h3>
            <% if (!overduePaymentRows.length) { %>
              <div class="empty-callout">No overdue family balances right now.</div>
            <% } else { %>
              <div class="breakdown-list">
                <% overduePaymentRows.forEach((row) => { %>
                  <div class="breakdown-row">
                    <div>
                      <p class="breakdown-label"><%= row.parentName %></p>
                      <p class="breakdown-meta"><%= row.studentName %> · <%= row.dueDateLabel %></p>
                    </div>
                    <strong><%= row.balanceLabel %></strong>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>

          <section class="finance-billing-side-card">
            <h3>Upcoming Due</h3>
            <% if (!upcomingPaymentRows.length) { %>
              <div class="empty-callout">No upcoming balances scheduled yet.</div>
            <% } else { %>
              <div class="breakdown-list">
                <% upcomingPaymentRows.forEach((row) => { %>
                  <div class="breakdown-row">
                    <div>
                      <p class="breakdown-label"><%= row.parentName %></p>
                      <p class="breakdown-meta"><%= row.title %> · <%= row.dueDateLabel %></p>
                    </div>
                    <strong><%= row.balanceLabel %></strong>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </section>
        </aside>
      </div>
    </article>

    <article class="finance-card" id="reconciliation">
      <header class="finance-card-header">
        <h2>Unmatched Bank Transactions</h2>
        <p>Manual reconciliation links bank feed records to finance entry records.</p>
      </header>
      <datalist id="financeEntryMatchList">
        <% entryMatchOptions.forEach((option) => { %>
          <option value="<%= option.id %>"><%= option.label %></option>
        <% }) %>
      </datalist>
      <div class="table-shell">
        <table class="finance-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Description</th>
              <th>Account</th>
              <th>Direction</th>
              <th>Amount</th>
              <th>Category</th>
              <th>Reconcile</th>
            </tr>
          </thead>
          <tbody id="financeUnmatchedBody">
            <% if (!unmatchedRows.length) { %>
              <tr><td colspan="7" class="empty-row">No unmatched bank transactions.</td></tr>
            <% } %>
            <% unmatchedRows.forEach((row) => { %>
              <tr>
                <td><%= row.dateLabel %></td>
                <td class="strong-cell"><%= row.description %></td>
                <td><%= row.accountName %></td>
                <td><%= row.direction %></td>
                <td class="mono-cell"><%= row.amountLabel %></td>
                <td><%= row.category %></td>
                <td>
                  <form class="reconcile-form" action="/admin/finance/reconcile" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="bankTransactionId" value="<%= row.id %>" />
                    <select name="action" required>
                      <option value="ignore">Ignore</option>
                      <option value="match_entry">Match Entry</option>
                    </select>
                    <input type="text" name="targetId" placeholder="Optional match id" />
                    <button type="submit" class="table-action">Apply</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>
  </div>

  <aside class="admin-side-column admin-utility-rail">
    <article class="finance-card bank-card" id="bank-sync">
      <header class="finance-card-header">
        <h2>Bank Sync</h2>
        <p>Provider: Plaid (<%= providerSummary.env || 'sandbox' %>)</p>
      </header>

      <div class="bank-status-list">
        <div class="bank-status-row">
          <span>Provider Credentials</span>
          <strong class="<%= providerSummary.configured ? 'ok' : 'warn' %>"><%= providerSummary.configured ? 'Configured' : 'Missing' %></strong>
        </div>
        <div class="bank-status-row">
          <span>Token Encryption</span>
          <strong class="<%= encryptionConfigured ? 'ok' : 'warn' %>"><%= encryptionConfigured ? 'Configured' : 'Missing FINANCE_ENCRYPTION_KEY' %></strong>
        </div>
        <div class="bank-status-row">
          <span>Last Sync Message</span>
          <strong id="financeLastSyncMessageValue"><%= summary.lastSyncMessage || 'No issues reported.' %></strong>
        </div>
      </div>

      <form id="financeLinkTokenForm" class="finance-inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="submit-btn secondary">Create Link Token</button>
        <input type="text" id="financeLinkTokenOutput" class="token-output" readonly placeholder="Link token appears here for Plaid Link integration" />
      </form>

      <form id="financeConnectForm" class="finance-inline-form" action="/admin/finance/bank/connect" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <input type="text" name="institutionName" placeholder="Institution name (optional)" />
        <input type="text" name="publicToken" required placeholder="Plaid public_token" />
        <button type="submit" class="submit-btn">Connect Bank</button>
      </form>

      <form id="financeSyncForm" class="finance-inline-form" action="/admin/finance/bank/sync" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <select name="connectionId">
          <option value="">Sync all connected accounts</option>
          <% connections.forEach((connection) => { %>
            <option value="<%= connection.id %>"><%= connection.institutionName %> · <%= connection.status %></option>
          <% }) %>
        </select>
        <button type="submit" class="submit-btn">Sync Bank Now</button>
      </form>

      <p id="financeActionStatus" class="finance-action-status" aria-live="polite"></p>
    </article>

    <article class="finance-card" id="categories">
      <header class="finance-card-header">
        <h2>Categories</h2>
        <p>Create and maintain income and expense categories.</p>
      </header>
      <form class="stacked-form" action="/admin/finance/categories" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-grid-two">
          <label>
            <span>Category Type</span>
            <select name="entryType" required>
              <option value="income">Income</option>
              <option value="expense">Expense</option>
            </select>
          </label>
          <label>
            <span>Label</span>
            <input type="text" name="label" maxlength="80" required placeholder="e.g. Transportation Reserve" />
          </label>
        </div>
        <button type="submit" class="submit-btn">Save Category</button>
      </form>
      <div class="category-columns">
        <div>
          <h3>Income</h3>
          <ul>
            <% (categories.income || []).forEach((row) => { %>
              <li><%= row.label %></li>
            <% }) %>
          </ul>
        </div>
        <div>
          <h3>Expenses</h3>
          <ul>
            <% (categories.expense || []).forEach((row) => { %>
              <li><%= row.label %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </article>

    <article class="finance-card" id="revenue-breakdown-panel">
      <header class="finance-card-header">
        <h2>Revenue Breakdown (<%= monthLabel %>)</h2>
        <p>Category-level incoming flow composition.</p>
      </header>
      <% if (!revenueBreakdown.length) { %>
        <div class="empty-callout">No revenue category totals yet for this month.</div>
      <% } else { %>
        <div class="breakdown-list">
          <% revenueBreakdown.forEach((row) => { %>
            <div class="breakdown-row">
              <div>
                <p class="breakdown-label"><%= row.label %></p>
                <p class="breakdown-meta"><%= row.percent %>%</p>
              </div>
              <strong><%= row.amountLabel %></strong>
            </div>
          <% }) %>
        </div>
      <% } %>
    </article>
  </aside>
</section>

<%- include('../partials/adminShellEnd', {
  pageScripts: ['/js/admin-finance.js']
}) %>
