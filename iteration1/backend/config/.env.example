# App
PORT=2121
NODE_ENV=production
APP_BASE_URL=https://your-domain.example

# Database
DB_STRING=your-mongodb-uri

# Session
# Use a long random value in production.
SESSION_SECRET=replace-with-a-long-random-secret

# Tenant admin safety controls
# Keep disabled in production unless you intentionally support tenant-admin school provisioning.
ALLOW_TENANT_ADMIN_SCHOOL_CREATION=false

# Admin dashboard analytics cache (milliseconds)
ADMIN_ANALYTICS_CACHE_TTL_MS=30000

# Email (SMTP)
# Optional: set SMTP_SERVICE (for example, `gmail`) instead of SMTP_HOST/SMTP_PORT.
SMTP_SERVICE=
SMTP_HOST=smtp.your-provider.example
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@your-domain.example

# IMPORTANT: when running behind reverse proxies/load balancers (Render/Heroku/Nginx/Cloudflare),
# the app must keep `app.set("trust proxy", 1)` in production so secure cookies can be set correctly.

# Cloudinary
# Preferred explicit keys:
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
# Optional single URL form:
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# Backward-compatible legacy names (still supported):
CLOUD_NAME=your-cloudinary-cloud-name
API_KEY=your-cloudinary-api-key
API_SECRET=your-cloudinary-api-secret

# Finance / Bank Sync (Plaid)
# Required for real bank link + sync flows:
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Optional:
PLAID_REDIRECT_URI=
PLAID_WEBHOOK_URL=
PLAID_PRODUCTS=transactions

# Finance token encryption (required to store bank access tokens securely)
FINANCE_ENCRYPTION_KEY=replace-with-a-long-random-secret
