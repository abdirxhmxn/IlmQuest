<%- include('partials/header') -%>

<link rel="stylesheet" href="/css/pages/auth.css" />

<div class="auth-shell">
  <div class="auth-panel">
    <div class="logo-section">
      <img src="/imgs/finalLogo.jpg" alt="IlmQuest Logo" class="logo-img logo-img-auth">
      <h1 class="logo-title">Forgot Password</h1>
      <p class="auth-subtitle">Enter your email and we will send a reset link.</p>
    </div>

    <% if (messages && (messages.errors || messages.info || messages.success)) { %>
      <div class="flash-messages">
        <% if (messages.errors) { %>
          <% messages.errors.forEach(msg=> { %>
            <div class="flash-message flash-error"><%= msg.msg %></div>
          <% }) %>
        <% } %>
        <% if (messages.info) { %>
          <% messages.info.forEach(msg=> { %>
            <div class="flash-message flash-info"><%= msg.msg %></div>
          <% }) %>
        <% } %>
        <% if (messages.success) { %>
          <% messages.success.forEach(msg=> { %>
            <div class="flash-message flash-info"><%= msg.msg %></div>
          <% }) %>
        <% } %>
      </div>
    <% } %>

    <form action="/forgot-password" method="POST" class="form-card">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <div class="form-group">
        <label for="email" class="form-label">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          placeholder="you@example.com"
          autocomplete="email"
          required
        />
      </div>

      <button type="submit" class="submit-btn">
        Send Reset Link
      </button>
    </form>

    <div class="signup-link">
      Remembered your password? <a href="/login">Back to sign in</a>
    </div>
  </div>
</div>

<%- include('partials/footer') -%>
