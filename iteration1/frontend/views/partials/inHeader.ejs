<%# Student shell header: shared global CSS architecture and student navigation controls. %>
<link rel="stylesheet" href="/css/base.css">
<link rel="stylesheet" href="/css/layout.css">
<link rel="stylesheet" href="/css/components.css">
<script src="/js/nav-toggle.js" defer></script>
<%
  const studentAvatarUrl = String(user?.profileImage || user?.profilePic || "").trim();
  const studentInitials = `${(user?.firstName || "S").charAt(0)}${(user?.lastName || user?.userName || "U").charAt(0)}`.toUpperCase();
%>
<header class="header-bar">
    <div class="header-left">
        <button class="logo-btn">
            <img src="/imgs/finalLogo.jpg" alt="IlmQuest" class="logo-img">
        </button>

        <div class="greeting">
            <!-- <h3>Assalāmu ʿalaykum,</h3> -->
            <h3>Welcome back,</h3>
            <h2>
                <%= user.firstName || "Guest" %>
            </h2>
        </div>
        <div class="header-user-avatar" aria-hidden="true">
            <% if (studentAvatarUrl) { %>
                <img src="<%= studentAvatarUrl %>" alt="" loading="lazy" />
            <% } else { %>
                <span><%= studentInitials %></span>
            <% } %>
        </div>
    </div>

    <button
        type="button"
        class="nav-toggle"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="student-nav"
        data-nav-toggle
    >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
    </button>

    <nav class="header-nav" id="student-nav" data-nav-menu>
        <ul class="nav-links" id="menu">
            <li><a href="/student/home">Home</a></li>
            <li><a href="/student/missions">Missions</a></li>
            <li><a href="/student/grades">Grades</a></li>
            <!-- <li><a href="/student/Library">Library</a></li> -->
            <li><a href="/profile">Profile</a></li>
            <!-- <li><a href="/logout">Logout</a></li> -->
        </ul>
    </nav>
</header>
