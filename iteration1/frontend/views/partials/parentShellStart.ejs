<%
  // Parent shell bootstrap: centralizes parent-level CSS architecture and sidebar/navigation rendering.
  const resolvedPageTitle = typeof pageTitle === "string" && pageTitle.trim().length
    ? pageTitle.trim()
    : "IlmQuest Parent Portal";
  const resolvedPageStyles = Array.isArray(pageStyles) ? pageStyles : [];
  const resolvedActivePage = typeof activePage === "string" ? activePage : "dashboard";
  const parentDisplayName = `${user?.firstName || "Parent"} ${user?.lastName || "User"}`.trim();
  const parentInitials = `${(user?.firstName || "P").charAt(0)}${(user?.lastName || "U").charAt(0)}`.toUpperCase();
  const parentAvatarUrl = String(user?.profileImage || user?.profilePic || "").trim();
  const hasParentAvatar = parentAvatarUrl.length > 0;
  const parentHandle = String(user?.userName || "").trim()
    || parentDisplayName.toLowerCase().replace(/\s+/g, "-")
    || String(user?.email || "").split("@")[0]
    || "parent";
  const parentRoleLabel = String(user?.role || user?.accountType || "Parent")
    .trim()
    .replace(/_/g, " ")
    .toUpperCase();

  function iconSvg(iconName) {
    const icons = {
      brand: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v12l-4-2-4 2-4-2-4 2V6a2 2 0 0 1 2-2z"/><path d="M9 8h6"/><path d="M9 12h6"/></svg>',
      menu: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>',
      dashboard: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="8" height="8" rx="2"/><rect x="13" y="3" width="8" height="5" rx="2"/><rect x="13" y="10" width="8" height="11" rx="2"/><rect x="3" y="13" width="8" height="8" rx="2"/></svg>',
      children: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 19a4 4 0 0 0-8 0"/><circle cx="12" cy="11" r="3"/><path d="M21 19a4 4 0 0 0-3-3.86"/></svg>',
      grades: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 19h16"/><path d="m7 16 3-4 3 2 4-6"/></svg>',
      attendance: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4"/><path d="M8 3v4"/><path d="M3 10h18"/><path d="m9 15 2 2 4-4"/></svg>',
      missions: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m12 3 2.9 5.88 6.5.95-4.7 4.57 1.1 6.46L12 17.9l-5.8 3.06 1.1-6.46L2.6 9.83l6.5-.95z"/></svg>',
      reports: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l5 5v13H7z"/><path d="M14 3v5h5"/><path d="M10 13h6"/><path d="M10 17h4"/></svg>',
      account: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20a8 8 0 0 1 16 0"/></svg>'
    };

    return icons[iconName] || icons.dashboard;
  }

  const navItems = [
    { key: "dashboard", href: "/parent/home", label: "Dashboard", icon: "dashboard" },
    { key: "children", href: "/parent/home#children", label: "Children", icon: "children" },
    { key: "grades", href: "/parent/home#grades", label: "Grades", icon: "grades" },
    { key: "attendance", href: "/parent/home#attendance", label: "Attendance", icon: "attendance" },
    { key: "missions", href: "/parent/home#missions", label: "Missions", icon: "missions" },
    { key: "reports", href: "/parent/home#reports", label: "Reports", icon: "reports" },
    { key: "account", href: "/profile", label: "Account", icon: "account" }
  ];
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= resolvedPageTitle %></title>
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/parent-shell.css" />
    <% resolvedPageStyles.forEach((styleHref) => { %>
      <link rel="stylesheet" href="<%= styleHref %>" />
    <% }) %>
    <link rel="stylesheet" href="/css/pages/app-shell.css" />
  </head>
  <body>
    <div
      class="parent-app-shell role-app-shell"
      id="parentShell"
      data-role-shell="parent"
      data-shell-role="parent"
      data-shell-storage-key="ilmquest_parent_sidebar_collapsed"
      data-shell-user-name="<%= parentDisplayName %>"
      data-shell-user-role="<%= parentRoleLabel %>"
      data-shell-active-key="<%= resolvedActivePage %>"
    >
      <aside class="parent-sidebar role-sidebar" id="parentSidebar" aria-label="Parent Navigation" data-shell-toggle-surface>
        <button
          type="button"
          class="parent-sidebar-brand role-sidebar-brand"
          data-parent-sidebar-logo-toggle
          aria-controls="parentSidebar"
          aria-label="Toggle sidebar"
        >
          <div class="parent-brand-icon role-brand-icon">
            <img src="/imgs/finalLogo.jpg" alt="IlmQuest logo" />
          </div>
          <div class="role-brand-meta">
            <p class="parent-brand-name role-brand-name">IlmQuest</p>
            <p class="parent-brand-role role-brand-role">PARENT PORTAL</p>
          </div>
        </button>

        <nav class="parent-sidebar-nav role-sidebar-nav">
          <% navItems.forEach((item) => { %>
            <a
              href="<%= item.href %>"
              class="parent-sidebar-link role-sidebar-link <%= resolvedActivePage === item.key ? "active" : "" %>"
              data-parent-nav-key="<%= item.key %>"
              data-shell-nav-key="<%= item.key %>"
              title="<%= item.label %>"
            >
              <span class="parent-sidebar-icon role-sidebar-icon"><%- iconSvg(item.icon) %></span>
              <span class="role-sidebar-label"><%= item.label %></span>
            </a>
          <% }) %>
        </nav>

        <a class="parent-sidebar-profile role-sidebar-profile" href="/profile" aria-label="Open profile">
          <div class="parent-profile-avatar role-profile-avatar">
            <% if (hasParentAvatar) { %>
              <img src="<%= parentAvatarUrl %>" alt="<%= parentDisplayName %> avatar" loading="lazy" />
            <% } else { %>
              <%= parentInitials %>
            <% } %>
          </div>
          <div class="parent-profile-meta role-profile-meta">
            <p class="parent-profile-name role-profile-name"><%= parentDisplayName %></p>
            <p class="parent-profile-role role-profile-role"><%= parentRoleLabel %></p>
            <p class="parent-profile-email">@<%= parentHandle %></p>
          </div>
        </a>
      </aside>
      <button
        type="button"
        class="parent-sidebar-scrim role-sidebar-scrim"
        data-parent-sidebar-scrim
        data-shell-scrim
        aria-label="Close sidebar"
      ></button>

      <main class="parent-main role-main-shell">
