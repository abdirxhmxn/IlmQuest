<%
  // Admin shell bootstrap: centralizes admin-level CSS architecture and sidebar/navigation rendering.
  const resolvedPageTitle = typeof pageTitle === "string" && pageTitle.trim().length
    ? pageTitle.trim()
    : "IlmQuest Admin";
  const resolvedPageStyles = Array.isArray(pageStyles) ? pageStyles : [];
  const resolvedActivePage = typeof activePage === "string" ? activePage : "dashboard";
  const adminDisplayName = `${user?.firstName || "Admin"} ${user?.lastName || "User"}`.trim();
  const adminInitials = `${(user?.firstName || "A").charAt(0)}${(user?.lastName || "U").charAt(0)}`.toUpperCase();
  const adminAvatarUrl = String(user?.profileImage || user?.profilePic || "").trim();
  const hasAdminAvatar = adminAvatarUrl.length > 0;
  const adminHandle = String(user?.userName || "").trim()
    || adminDisplayName.toLowerCase().replace(/\s+/g, "-")
    || String(user?.email || "").split("@")[0]
    || "admin";
  const adminRoleLabel = String(user?.role || user?.accountType || "Admin")
    .trim()
    .replace(/_/g, " ")
    .toUpperCase();

  function iconSvg(iconName) {
    const icons = {
      brand: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v12l-4-2-4 2-4-2-4 2V6a2 2 0 0 1 2-2z"/><path d="M9 8h6"/><path d="M9 12h6"/></svg>',
      menu: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16"/><path d="M4 12h16"/><path d="M4 17h16"/></svg>',
      dashboard: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="3" width="8" height="8" rx="2"/><rect x="13" y="3" width="8" height="5" rx="2"/><rect x="13" y="10" width="8" height="11" rx="2"/><rect x="3" y="13" width="8" height="8" rx="2"/></svg>',
      students: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 19a4 4 0 0 0-8 0"/><circle cx="12" cy="11" r="3"/><path d="M21 19a4 4 0 0 0-3-3.86"/><path d="M6 15.14A4 4 0 0 0 3 19"/></svg>',
      classes: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m4 9 8-4 8 4-8 4-8-4z"/><path d="m6 10.5 6 3 6-3"/><path d="M6 14.5l6 3 6-3"/></svg>',
      attendance: '<svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M16 3v4"/><path d="M8 3v4"/><path d="M3 10h18"/><path d="m9 15 2 2 4-4"/></svg>',
      income: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 4h16v16H4z"/><path d="M8 9h8"/><path d="M8 13h8"/><path d="M8 17h5"/></svg>',
      announcements: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 11h3l9-4v10l-9-4H3z"/><path d="M15 9a4 4 0 0 1 0 6"/><path d="M7 14v3a2 2 0 0 0 2 2h1"/></svg>',
      reports: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l5 5v13H7z"/><path d="M14 3v5h5"/><path d="M10 13h6"/><path d="M10 17h4"/></svg>',
      settings: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.6 1.6 0 0 0 .32 1.76l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.6 1.6 0 0 0-1.76-.32 1.6 1.6 0 0 0-.97 1.46V21a2 2 0 1 1-4 0v-.09a1.6 1.6 0 0 0-.97-1.46 1.6 1.6 0 0 0-1.76.32l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.6 1.6 0 0 0 4.6 15a1.6 1.6 0 0 0-1.46-.97H3a2 2 0 1 1 0-4h.09A1.6 1.6 0 0 0 4.6 8.57a1.6 1.6 0 0 0-.32-1.76l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.6 1.6 0 0 0 1.76.32H9a1.6 1.6 0 0 0 .97-1.46V3a2 2 0 1 1 4 0v.09a1.6 1.6 0 0 0 .97 1.46h.13a1.6 1.6 0 0 0 1.76-.32l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.6 1.6 0 0 0-.32 1.76V9c0 .66.39 1.26.99 1.5h.09a2 2 0 1 1 0 4h-.09c-.6.24-.99.84-.99 1.5z"/></svg>',
      search: '<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>',
      bell: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"/><path d="M9 17a3 3 0 0 0 6 0"/></svg>',
      activity: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 12h4l2-5 4 10 2-5h4"/></svg>',
      delete: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M6 7l1 12h10l1-12"/><path d="M9 7V5h6v2"/></svg>',
      chevron: '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 6 6 6-6 6"/></svg>'
    };

    return icons[iconName] || icons.dashboard;
  }

  const navSections = [
    {
      title: 'Overview',
      items: [
        { key: 'dashboard', href: '/admin/home', label: 'Dashboard', icon: 'dashboard', aliases: [] }
      ]
    },
    {
      title: 'Operations',
      items: [
        { key: 'students', href: '/admin/users', label: 'Users', icon: 'students', aliases: [] },
        { key: 'classes', href: '/admin/classes', label: 'Classes', icon: 'classes', aliases: [] },
        { key: 'attendance', href: '/admin/attendance', label: 'Attendance', icon: 'attendance', aliases: [] }
      ]
    },
    {
      title: 'Insights',
      items: [
        { key: 'announcements', href: '/admin/announcements', label: 'Announcements', icon: 'announcements', aliases: [] },
        { key: 'reports', href: '/admin/reports', label: 'Reports', icon: 'reports', aliases: [] },
        { key: 'settings', href: '/admin/settings', label: 'Settings', icon: 'settings', aliases: [] }
      ]
    }
  ];
%>
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= resolvedPageTitle %></title>
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/layout.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link rel="stylesheet" href="/css/pages/admin-shell.css" />
    <% resolvedPageStyles.forEach((styleHref) => { %>
      <link rel="stylesheet" href="<%= styleHref %>" />
    <% }) %>
    <link rel="stylesheet" href="/css/pages/app-shell.css" />
  </head>
  <body>
    <div
      class="admin-app-shell role-app-shell"
      id="adminShell"
      data-role-shell="admin"
      data-shell-role="admin"
      data-shell-storage-key="ilmquest_admin_sidebar_collapsed"
      data-shell-active-key="<%= resolvedActivePage %>"
      data-shell-user-name="<%= adminDisplayName %>"
      data-shell-user-role="<%= adminRoleLabel %>"
    >
      <aside class="admin-sidebar role-sidebar" id="adminSidebar" aria-label="Admin Navigation" data-shell-toggle-surface>
        <button
          type="button"
          class="sidebar-brand role-sidebar-brand"
          data-sidebar-logo-toggle
          aria-controls="adminSidebar"
          aria-label="Toggle sidebar"
        >
          <div class="brand-icon role-brand-icon">
            <img src="/imgs/finalLogo.jpg" alt="IlmQuest logo" />
          </div>
          <div class="role-brand-meta">
            <p class="brand-name role-brand-name">IlmQuest</p>
            <p class="brand-role role-brand-role">Admin Workspace</p>
          </div>
        </button>

        <div class="sidebar-search-shell" aria-hidden="true">
          <span class="sidebar-search-icon"><%- iconSvg('search') %></span>
          <input type="search" placeholder="Search workspace" tabindex="-1" />
        </div>

        <nav class="sidebar-nav role-sidebar-nav">
          <% navSections.forEach((section) => { %>
            <section class="sidebar-nav-group" aria-label="<%= section.title %>">
              <p class="sidebar-nav-label"><%= section.title %></p>
              <div class="sidebar-nav-links">
                <% section.items.forEach((item) => { %>
                  <% const isActive = resolvedActivePage === item.key || (Array.isArray(item.aliases) && item.aliases.includes(resolvedActivePage)); %>
                  <a href="<%= item.href %>" class="sidebar-link role-sidebar-link <%= isActive ? 'active' : '' %>" data-shell-nav-key="<%= item.key %>" title="<%= item.label %>">
                    <span class="sidebar-icon role-sidebar-icon"><%- iconSvg(item.icon) %></span>
                    <span class="sidebar-link-label role-sidebar-label"><%= item.label %></span>
                  </a>
                <% }) %>
              </div>
            </section>
          <% }) %>
        </nav>

        <a class="sidebar-profile role-sidebar-profile" href="/profile" aria-label="Open profile">
          <div class="profile-avatar role-profile-avatar">
            <% if (hasAdminAvatar) { %>
              <img src="<%= adminAvatarUrl %>" alt="<%= adminDisplayName %> avatar" loading="lazy" />
            <% } else { %>
              <%= adminInitials %>
            <% } %>
          </div>
          <div class="profile-meta role-profile-meta">
            <p class="profile-name role-profile-name"><%= adminDisplayName %></p>
            <p class="profile-role role-profile-role"><%= adminRoleLabel %></p>
            <p class="profile-email">@<%= adminHandle %></p>
          </div>
        </a>
      </aside>
      <button
        type="button"
        class="admin-sidebar-scrim role-sidebar-scrim"
        data-admin-sidebar-scrim
        data-shell-scrim
        aria-label="Close sidebar"
      ></button>

      <main class="admin-main role-main-shell">
