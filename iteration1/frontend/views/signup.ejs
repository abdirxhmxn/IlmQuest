<%- include('partials/header') -%>

<link rel="stylesheet" href="/css/pages/auth-shell.css" />

<main class="auth-page auth-page-signup">
  <section class="auth-layout" aria-labelledby="signup-title">
    <%- include('partials/authBrandPanel', {
      eyebrow: 'JOIN ILMQUEST',
      headingTop: 'Build your',
      headingAccent: 'learning community',
      supportingText: "Launch your school portal with secure administration, structured learning pathways, and parent engagement from day one."
    }) %>

    <section class="auth-form-panel">
      <div class="auth-form-wrap auth-form-wrap-signup">
        <header class="auth-form-header">
          <h1 id="signup-title">Create your account</h1>
          <p>Set up your school and start onboarding students in minutes</p>
        </header>

        <% if (messages && (messages.errors || messages.info)) { %>
          <div class="flash-messages" role="status" aria-live="polite">
            <% if (messages.errors) { %>
              <% messages.errors.forEach(msg => { %>
                <div class="flash-message flash-error"><%= msg.msg %></div>
              <% }) %>
            <% } %>
            <% if (messages.info) { %>
              <% messages.info.forEach(msg => { %>
                <div class="flash-message flash-info"><%= msg.msg %></div>
              <% }) %>
            <% } %>
          </div>
        <% } %>

        <div class="auth-divider" role="presentation">
          <span>Account details</span>
        </div>

        <form action="/signup" method="POST" class="auth-form auth-signup-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="form-group auth-field auth-field-full">
            <label for="schoolName" class="form-label auth-label">School / Organization Name</label>
            <div class="auth-field-control">
              <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="auth-icon"><path d="m3 9 9-6 9 6"></path><path d="M4 10h16v10H4z"></path><path d="M8 20v-6h8v6"></path></svg>
              </span>
              <input type="text" id="schoolName" name="schoolName" class="form-input auth-input" placeholder="Al Noor Academy" required>
            </div>
          </div>

          <div class="form-group auth-field auth-field-full">
            <label for="adminName" class="form-label auth-label">Administrator Full Name</label>
            <div class="auth-field-control">
              <span class="auth-input-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="auth-icon"><circle cx="12" cy="8" r="4"></circle><path d="M4 20a8 8 0 0 1 16 0"></path></svg>
              </span>
              <input type="text" id="adminName" name="adminName" class="form-input auth-input" placeholder="Your Full Name" required>
            </div>
          </div>

          <div class="auth-field-grid">
            <div class="form-group auth-field split-col">
              <label for="email" class="form-label auth-label">Work Email Address</label>
              <div class="auth-field-control">
                <span class="auth-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="auth-icon"><path d="M3 6h18v12H3z"></path><path d="m3 7 9 7 9-7"></path></svg>
                </span>
                <input type="email" id="email" name="email" class="form-input auth-input" placeholder="admin@school.edu" required>
              </div>
            </div>

            <div class="form-group auth-field split-col">
              <label for="phone" class="form-label auth-label">Phone Number</label>
              <div class="auth-field-control">
                <span class="auth-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="auth-icon"><path d="M5 4h4l2 5-2.5 2.5a16 16 0 0 0 4 4L15 13l5 2v4a2 2 0 0 1-2 2A15 15 0 0 1 3 6a2 2 0 0 1 2-2z"></path></svg>
                </span>
                <input type="text" id="phone" name="phone" class="form-input auth-input" placeholder="(555) 123-4567" required>
              </div>
            </div>
          </div>

          <div class="auth-field-grid">
            <div class="form-group auth-field split-col">
              <label for="adminUser" class="form-label auth-label">Username</label>
              <div class="auth-field-control">
                <span class="auth-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="auth-icon"><circle cx="12" cy="8" r="4"></circle><path d="M4 20a8 8 0 0 1 16 0"></path></svg>
                </span>
                <input type="text" id="adminUser" name="adminUser" class="form-input auth-input" required placeholder="Create a username">
              </div>
            </div>

            <div class="form-group auth-field split-col">
              <label for="confirmUsername" class="form-label auth-label">Confirm Username</label>
              <div class="auth-field-control">
                <span class="auth-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="auth-icon"><circle cx="12" cy="8" r="4"></circle><path d="M4 20a8 8 0 0 1 16 0"></path></svg>
                </span>
                <input type="text" id="confirmUsername" name="confirmUsername" class="form-input auth-input" required placeholder="Re-enter your username">
              </div>
            </div>
          </div>

          <div class="auth-field-grid">
            <div class="form-group auth-field split-col">
              <label for="password" class="form-label auth-label">Password</label>
              <div class="auth-field-control">
                <span class="auth-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="auth-icon"><rect x="5" y="10" width="14" height="10" rx="2"></rect><path d="M8 10V7a4 4 0 1 1 8 0v3"></path></svg>
                </span>
                <input type="password" id="password" name="password" class="form-input auth-input" required placeholder="Create a password">
              </div>
            </div>

            <div class="form-group auth-field split-col">
              <label for="confirmPassword" class="form-label auth-label">Confirm Password</label>
              <div class="auth-field-control">
                <span class="auth-input-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="auth-icon"><rect x="5" y="10" width="14" height="10" rx="2"></rect><path d="M8 10V7a4 4 0 1 1 8 0v3"></path></svg>
                </span>
                <input type="password" id="confirmPassword" name="confirmPassword" class="form-input auth-input" required placeholder="Re-enter your password">
              </div>
            </div>
          </div>

          <button type="submit" class="submit-btn auth-submit">
            Create School Account
            <svg viewBox="0 0 24 24" class="auth-icon" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
          </button>
        </form>

        <p class="auth-switch-link">
          Already registered?
          <a href="/login">Sign in</a>
        </p>

        <p class="auth-copyright">&copy; <%= new Date().getFullYear() %> IlmQuest. All rights reserved.</p>
      </div>
    </section>
  </section>
</main>

<%- include('partials/footer') -%>
